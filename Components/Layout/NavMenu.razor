@inject AuthStateService AuthState

<header class="app-header">
    <div class="header-inner">
        <a href="" class="brand-link">
            <svg class="brand-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5S19.33 12 18.5 12z"/>
            </svg>
            <span class="brand-name">HMGHIP</span>
        </a>
        <button class="profile-btn @(_profileOpen ? "profile-btn-active" : "")"
                @onclick="ToggleProfile" @onclick:stopPropagation aria-label="Profile">
            @if (AuthState.CurrentUser?.PhotoUrl != null)
            {
                <img src="@AuthState.CurrentUser.PhotoUrl" class="profile-avatar" alt="avatar" />
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            }
        </button>
    </div>
</header>

@if (_profileOpen)
{
    <div class="profile-backdrop" @onclick="CloseProfile"></div>
    <div class="profile-dropdown">
        @if (AuthState.CurrentUser != null)
        {
            <div class="profile-menu-user">
                <span class="profile-menu-name">@AuthState.CurrentUser.DisplayName</span>
                <span class="profile-menu-email">@AuthState.CurrentUser.Email</span>
            </div>
            <div class="profile-menu-divider"></div>
        }
        <a href="profile" class="profile-menu-item" @onclick="CloseProfile">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
            My Profile
        </a>
        <div class="profile-menu-divider"></div>
        @if (!AuthState.IsAuthenticated || AuthState.IsGuest)
        {
            <a href="login" class="profile-menu-item" @onclick="CloseProfile">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11 7L9.6 8.4l2.6 2.6H2v2h10.2l-2.6 2.6L11 17l5-5-5-5zm9 12h-8v2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-8v2h8v14z"/></svg>
                Log In
            </a>
        }
        else
        {
            <a href="logout" class="profile-menu-item profile-menu-danger" @onclick="CloseProfile">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                Log Out
            </a>
        }
    </div>
}

@code {
    private bool _profileOpen;

    private void ToggleProfile() => _profileOpen = !_profileOpen;
    private void CloseProfile()  => _profileOpen = false;
}
