@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject AuthStateService AuthState
@inject FirebaseService Firebase
@inject RawgService RawgService
@inject GameStateService GameState
@inject NavigationManager Nav

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<NavMenu />

<div class="global-search-bar">
    <div class="global-search-inner">
        <svg class="global-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
        <input type="search" class="global-search-input"
               placeholder="Search games..."
               value="@_query" @oninput="OnQueryInput" />
        @if (_searching)
        {
            <span class="global-search-spinner" aria-hidden="true"></span>
        }
        else if (!string.IsNullOrEmpty(_query))
        {
            <button class="global-search-clear" @onclick="ClearSearch" aria-label="Clear">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_query) && !_searching && _results.Count == 0 && _searched)
    {
        <div class="global-search-results">
            <div class="global-search-empty">No games found for "@_query"</div>
        </div>
    }
    else if (_results.Count > 0)
    {
        <div class="global-search-results">
            @foreach (var r in _results)
            {
                <button class="global-search-result" @onclick="() => OpenGame(r)">
                    @if (!string.IsNullOrEmpty(r.ArtUrl))
                    {
                        <img src="@r.ArtUrl" class="global-search-result-img" alt="" />
                    }
                    else
                    {
                        <div class="global-search-result-img global-search-result-noimg"></div>
                    }
                    <div class="global-search-result-text">
                        <div class="global-search-result-name">@r.Name</div>
                        @if (!string.IsNullOrEmpty(r.Genre))
                        {
                            <div class="global-search-result-genre">@r.Genre</div>
                        }
                    </div>
                </button>
            }
        </div>
    }
</div>

<div class="app-shell">
    @Body
</div>

<BottomTabBar />

@if (_open != null)
{
    <div class="popup-overlay" @onclick="CloseDetail">
        <div class="popup-sheet game-detail-sheet" @onclick:stopPropagation>
            <div class="popup-handle-bar"></div>

            @if (_mode == "actions")
            {
                <div class="game-detail-art" style="background: @GenreGradient(_open.Genre)">
                    @if (!string.IsNullOrEmpty(_open.ArtUrl))
                    {
                        <img src="@_open.ArtUrl" alt="@_open.Name" class="game-detail-art-img" />
                    }
                </div>
                <p class="popup-game-name">@_open.Name</p>
                @if (!string.IsNullOrEmpty(_detail?.Genre ?? _open.Genre))
                {
                    <p class="popup-genre">@(_detail?.Genre ?? _open.Genre)</p>
                }

                @if (_detailLoading && _detail == null)
                {
                    <div class="game-detail-loading">Loading details…</div>
                }
                else if (_detail != null)
                {
                    <dl class="game-detail-meta">
                        @if (!string.IsNullOrEmpty(_detail.Released))
                        {
                            <div><dt>Released</dt><dd>@FormatReleased(_detail.Released)</dd></div>
                        }
                        @if (!string.IsNullOrEmpty(_detail.Developer))
                        {
                            <div><dt>Developer</dt><dd>@_detail.Developer</dd></div>
                        }
                        @if (!string.IsNullOrEmpty(_detail.Publisher))
                        {
                            <div><dt>Publisher</dt><dd>@_detail.Publisher</dd></div>
                        }
                        @if (_detail.Platforms.Count > 0)
                        {
                            <div><dt>Platforms</dt><dd>@string.Join(", ", _detail.Platforms)</dd></div>
                        }
                        @if (_detail.Metacritic.HasValue)
                        {
                            <div><dt>Metacritic</dt><dd>@_detail.Metacritic</dd></div>
                        }
                    </dl>
                    @if (!string.IsNullOrWhiteSpace(_detail.Description))
                    {
                        <div class="game-detail-about">
                            <h4 class="game-detail-about-title">About</h4>
                            <p class="game-detail-about-text @(_aboutExpanded ? "expanded" : "")">@_detail.Description</p>
                            @if (_detail.Description.Length > 280)
                            {
                                <button class="game-detail-about-toggle" @onclick="() => _aboutExpanded = !_aboutExpanded">
                                    @(_aboutExpanded ? "Show less" : "Read more")
                                </button>
                            }
                        </div>
                    }
                }

                @if (AuthState.CurrentUser == null)
                {
                    <div class="popup-signin-note">Sign in to track this game.</div>
                }
                else
                {
                    <div class="card-actions detail-actions">
                        <button class="card-action-btn card-action-want @(_isWantToPlay ? "action-active" : "")"
                                @onclick="ToggleWantToPlay" disabled="@_saving">
                            @if (_isWantToPlay)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2zm0 15-5-2.18L7 18V5h10v13z"/></svg>
                            }
                            Want to Play
                        </button>
                        <button class="card-action-btn card-action-playing @(_isPlaying ? "action-active" : "")"
                                @onclick="TogglePlaying" disabled="@_saving">
                            @if (_isPlaying)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                            }
                            Playing
                        </button>
                        <button class="card-action-btn card-action-finished @(_isFinished ? "action-active" : "")"
                                @onclick='() => _mode = "finished"' disabled="@_saving">
                            @if (_isFinished)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                            }
                            Finished
                        </button>
                        <button class="card-action-btn card-action-review @(_existingReview > 0 ? "action-active" : "")"
                                @onclick='() => _mode = "review"' disabled="@_saving">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                            Review
                        </button>
                    </div>
                }
            }
            else if (_mode == "finished")
            {
                <p class="popup-title">Mark as Finished</p>
                <p class="popup-game-name">@_open.Name</p>

                <div class="finished-form">
                    <div class="finished-field">
                        <label class="finished-label">Platform</label>
                        <MudSelect T="string" @bind-Value="_platform" Variant="Variant.Outlined"
                                   Dense="true" FullWidth="true" Placeholder="Pick a platform">
                            @foreach (var p in AvailablePlatforms)
                            {
                                <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <div class="finished-field">
                        <label class="finished-label">Hours Played</label>
                        <MudNumericField @bind-Value="_hours" Variant="Variant.Outlined"
                                         Min="0.0" Step="0.5" FullWidth="true" />
                    </div>

                    <div class="finished-field">
                        <label class="finished-label">Rating</label>
                        <div class="star-rating-row">
                            <MudRating @bind-SelectedValue="_stars" MaxValue="5" Color="Color.Warning" />
                            <span class="star-score-label">@(_stars * 2) / 10</span>
                        </div>
                    </div>

                    <div class="finished-field">
                        <label class="finished-label">Review</label>
                        <MudTextField @bind-Value="_reviewText" Lines="3" Placeholder="Your thoughts (optional)..."
                                      Variant="Variant.Outlined" FullWidth="true" />
                    </div>

                    <button class="like-btn @(_liked ? "like-btn-on" : "")" @onclick="() => _liked = !_liked" type="button">
                        @if (_liked)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                            <span>Liked</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c-1.74 0-3.41.81-4.5 2.09C10.91 3.81 9.24 3 7.5 3 4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5 22 5.42 19.58 3 16.5 3zM12 19.55l-.1-.1C7.14 15.24 4 12.39 4 8.5 4 6.5 5.5 5 7.5 5c1.54 0 3.04.99 3.57 2.36h1.87C13.46 5.99 14.96 5 16.5 5c2 0 3.5 1.5 3.5 3.5 0 3.89-3.14 6.74-7.9 11.05l-.1.1z"/></svg>
                            <span>Like</span>
                        }
                    </button>
                </div>

                <div class="popup-actions">
                    <MudButton Variant="Variant.Text" OnClick='() => _mode = "actions"'>Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveFinished" Disabled="_saving">
                        @(_saving ? "Saving..." : "Save")
                    </MudButton>
                </div>
            }
            else if (_mode == "review")
            {
                <p class="popup-title">Write a Review</p>
                <p class="popup-game-name">@_open.Name</p>
                <div class="star-rating-row">
                    <MudRating @bind-SelectedValue="_stars" MaxValue="5" Color="Color.Warning" />
                    <span class="star-score-label">@(_stars * 2) / 10</span>
                </div>
                <MudTextField @bind-Value="_reviewText" Label="Your thoughts..." Lines="4"
                              Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
                <div class="popup-actions">
                    <MudButton Variant="Variant.Text" OnClick='() => _mode = "actions"'>Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="SaveReview" Disabled="@(_saving || _stars == 0)">
                        @(_saving ? "Saving..." : "Save Review")
                    </MudButton>
                </div>
            }
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly string[] AuthRoutes = ["/login", "/logout", "/auth/", "/setup"];

    // Search state
    private string _query = "";
    private List<RawgSearchResult> _results = new();
    private bool _searching;
    private bool _searched;
    private int _searchToken;

    // Detail popup state
    private RawgSearchResult? _open;
    private RawgGameDetail?   _detail;
    private bool              _detailLoading;
    private string _mode = "actions";
    private bool _isPlaying;
    private bool _isFinished;
    private bool _isWantToPlay;
    private bool _liked;
    private double _existingReview;
    private double _hours;
    private string _platform = "";
    private int _stars = 3;
    private string _reviewText = "";
    private bool _saving;
    private bool _aboutExpanded;

    private static readonly string[] FallbackPlatforms = new[]
    {
        "PC", "PlayStation 5", "PlayStation 4", "Xbox Series X/S", "Xbox One",
        "Nintendo Switch", "iOS", "Android", "Steam Deck", "Mac"
    };
    private IEnumerable<string> AvailablePlatforms =>
        (_detail?.Platforms is { Count: > 0 } p ? p : FallbackPlatforms);

    // ── Search ────────────────────────────────────────────────────────────

    private async Task OnQueryInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        var token = ++_searchToken;

        if (string.IsNullOrWhiteSpace(_query))
        {
            _results = new();
            _searching = false;
            _searched = false;
            return;
        }

        await Task.Delay(300);
        if (token != _searchToken) return;

        _searching = true;
        StateHasChanged();

        var res = await RawgService.SearchGamesAsync(_query);
        if (token != _searchToken) return;

        _results = res;
        _searching = false;
        _searched = true;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        _query = "";
        _results = new();
        _searching = false;
        _searched = false;
        _searchToken++;
    }

    // ── Detail popup ──────────────────────────────────────────────────────

    private async Task OpenGame(RawgSearchResult r, string mode = "actions")
    {
        _open = r;
        _detail = null;
        _detailLoading = true;
        _mode = mode;
        _isPlaying = false;
        _isFinished = false;
        _isWantToPlay = false;
        _liked = false;
        _existingReview = 0;
        _hours = 0;
        _platform = "";
        _stars = 3;
        _reviewText = "";

        ClearSearch();

        // Fetch RAWG details in the background — doesn't block opening
        _ = LoadDetailAsync(r.Name);

        if (AuthState.CurrentUser == null) return;

        var statuses = await Firebase.GetGameStatusesAsync(AuthState.CurrentUser.Uid);
        if (statuses.TryGetValue(r.Name, out var status))
        {
            _isPlaying     = status == "playing";
            _isFinished    = status == "finished";
            _isWantToPlay  = status == "want_to_play";
        }

        var games = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);
        var existing = games.FirstOrDefault(g =>
            string.Equals(g.Name, r.Name, StringComparison.OrdinalIgnoreCase));
        if (existing != null)
        {
            _hours          = existing.HoursPlayed;
            _platform       = existing.System ?? "";
            _liked          = existing.Liked;
            _existingReview = existing.Review;
            if (existing.Review > 0) _stars = (int)Math.Round(existing.Review / 2.0);
            _reviewText     = existing.ReviewText ?? "";
        }
        StateHasChanged();
    }

    private async Task LoadDetailAsync(string name)
    {
        var d = await RawgService.GetGameDetailsAsync(name);
        // Guard: user may have closed/switched popup before details arrive
        if (_open == null || !string.Equals(_open.Name, name, StringComparison.OrdinalIgnoreCase)) return;
        _detail = d;
        _detailLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void CloseDetail()
    {
        _open = null;
        _detail = null;
        _aboutExpanded = false;
        _mode = "actions";
    }

    private async Task<List<Games>> EnsureSavedAsync()
    {
        var games = await Firebase.GetGamesAsync(AuthState.CurrentUser!.Uid);
        if (!games.Any(g => string.Equals(g.Name, _open!.Name, StringComparison.OrdinalIgnoreCase)))
        {
            games.Add(new Games
            {
                Name       = _open!.Name,
                GameArtUrl = _open.ArtUrl,
                Genre      = _open.Genre ?? "Other",
                Year       = DateTime.Now.Year,
            });
        }
        return games;
    }

    private async Task TogglePlaying()
    {
        if (_open == null || AuthState.CurrentUser == null) return;
        _saving = true;

        _isPlaying = !_isPlaying;
        if (_isPlaying) { _isFinished = false; _isWantToPlay = false; }

        var status = _isPlaying ? "playing" : "none";
        await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, _open.Name, status);

        var games = await EnsureSavedAsync();
        await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, games);

        _saving = false;
        GameState.NotifyChanged();
    }

    private async Task ToggleWantToPlay()
    {
        if (_open == null || AuthState.CurrentUser == null) return;
        _saving = true;

        _isWantToPlay = !_isWantToPlay;
        if (_isWantToPlay) { _isPlaying = false; _isFinished = false; }

        var status = _isWantToPlay ? "want_to_play" : "none";
        await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, _open.Name, status);

        var games = await EnsureSavedAsync();
        await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, games);

        _saving = false;
        GameState.NotifyChanged();
    }

    private async Task SaveFinished()
    {
        if (_open == null || AuthState.CurrentUser == null) return;
        _saving = true;

        var games = await EnsureSavedAsync();
        var game = games.First(g => string.Equals(g.Name, _open.Name, StringComparison.OrdinalIgnoreCase));
        game.HoursPlayed = _hours;
        game.System      = string.IsNullOrWhiteSpace(_platform) ? null : _platform;
        game.Liked       = _liked;
        if (_stars > 0) game.Review = _stars * 2.0;
        if (!string.IsNullOrWhiteSpace(_reviewText)) game.ReviewText = _reviewText;
        await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, games);
        await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, _open.Name, "finished");

        _existingReview = game.Review;
        _isFinished = true;
        _isPlaying  = false;
        _isWantToPlay = false;
        _mode = "actions";
        _saving = false;
        GameState.NotifyChanged();
    }

    private async Task SaveReview()
    {
        if (_open == null || AuthState.CurrentUser == null) return;
        _saving = true;

        var games = await EnsureSavedAsync();
        var game = games.First(g => string.Equals(g.Name, _open.Name, StringComparison.OrdinalIgnoreCase));
        game.Review     = _stars * 2.0;
        game.ReviewText = _reviewText;
        await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, games);

        _existingReview = game.Review;
        _mode = "actions";
        _saving = false;
        GameState.NotifyChanged();
    }

    private static string FormatReleased(string iso)
    {
        // RAWG returns "YYYY-MM-DD"
        if (DateTime.TryParse(iso, out var dt)) return dt.ToString("MMM d, yyyy");
        return iso;
    }

    private static string GenreGradient(string? genre) => genre switch
    {
        "Action RPG"       => "linear-gradient(145deg, #1e0a3c 0%, #6b21a8 100%)",
        "RPG"              => "linear-gradient(145deg, #0d1b4b 0%, #1d4ed8 100%)",
        "Action-Adventure" => "linear-gradient(145deg, #1c0505 0%, #991b1b 100%)",
        "JRPG"             => "linear-gradient(145deg, #3b0000 0%, #dc2626 100%)",
        "Roguelike"        => "linear-gradient(145deg, #0a0a1a 0%, #4338ca 100%)",
        "Metroidvania"     => "linear-gradient(145deg, #000d10 0%, #0e7490 100%)",
        "Simulation"       => "linear-gradient(145deg, #0a1a0a 0%, #15803d 100%)",
        "MMORPG"           => "linear-gradient(145deg, #1a1000 0%, #b45309 100%)",
        "Action"           => "linear-gradient(145deg, #1a0a00 0%, #c2410c 100%)",
        "Platformer"       => "linear-gradient(145deg, #0a1a2a 0%, #0369a1 100%)",
        "Racing"           => "linear-gradient(145deg, #1a0a00 0%, #d97706 100%)",
        _                  => "linear-gradient(145deg, #1a1a2e 0%, #374151 100%)",
    };

    // ── Auth bootstrap ────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            try { await JS.InvokeVoidAsync("_appReady"); } catch { }
    }

    private async void OnOpenGameRequested(string name, string? artUrl, string? genre, string mode)
    {
        await OpenGame(new RawgSearchResult(name, artUrl, genre), mode);
    }

    public void Dispose()
    {
        GameState.OnOpenGameRequested -= OnOpenGameRequested;
    }

    protected override async Task OnInitializedAsync()
    {
        GameState.OnOpenGameRequested += OnOpenGameRequested;

        if (!AuthState.IsAuthenticated)
        {
            var user = await Firebase.GetCurrentUserAsync();
            if (user != null)
                AuthState.SignInWithUser(user);
        }

        var path = "/" + Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/');
        var onAuthPage = AuthRoutes.Any(r => path.StartsWith(r, StringComparison.OrdinalIgnoreCase));

        if (!AuthState.IsAuthenticated && !onAuthPage)
        {
            Nav.NavigateTo("login", replace: true);
            return;
        }

        if (AuthState.CurrentUser != null && !onAuthPage)
        {
            var profile = await Firebase.GetProfileAsync(AuthState.CurrentUser.Uid);
            if (profile == null || !profile.IsComplete)
                Nav.NavigateTo("setup", replace: true);
        }
    }
}
