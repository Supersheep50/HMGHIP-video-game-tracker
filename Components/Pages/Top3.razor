@page "/top3"
@inject RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState
@inject XpService Xp

<PageTitle>Top 3 — HMGHIP</PageTitle>

<div class="hero-header">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">All Time</div>
            <p class="hero-title">My Top 3</p>
            <p class="hero-subtitle">The three games I'd take to a desert island</p>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    @if (AuthState.CurrentUser == null)
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 4rem; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Class="mt-3">Sign in to pick your Top 3</MudText>
        </div>
    }
    else
    {
        <div class="top3-grid">
            @for (int i = 0; i < 3; i++)
            {
                var idx = i;
                var slot = _slots[idx];
                <div class="top3-slot @(slot == null ? "top3-slot-empty" : "")" @onclick="() => OpenPicker(idx)">
                    @if (slot == null)
                    {
                        <div class="top3-rank">#@(idx + 1)</div>
                        <svg class="top3-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                        </svg>
                        <span class="top3-add-label">Add Game</span>
                    }
                    else
                    {
                        <div class="top3-art" style="@(slot.ArtUrl != null ? $"background-image:url('{slot.ArtUrl}')" : $"background:{GameVisuals.Gradient(slot.Genre)}")"></div>
                        <div class="top3-info-overlay">
                            <span class="top3-rank-badge">#@(idx + 1)</span>
                            <p class="top3-game-name">@slot.Name</p>
                            @if (slot.Score is double s and > 0)
                            {
                                <p class="top3-game-score">@s.ToString("F1")<span class="top3-score-sub">/10</span></p>
                            }
                        </div>
                        <button class="top3-remove" @onclick:stopPropagation @onclick="() => RemoveSlot(idx)">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                        </button>
                    }
                </div>
            }
        </div>
    }

</MudContainer>

@if (_pickerOpen)
{
    <div class="picker-backdrop" @onclick="ClosePicker"></div>
    <div class="picker-sheet">
        <div class="drawer-handle-bar"></div>
        <div class="picker-header">
            <span class="picker-title">Choose a Game</span>
        </div>
        <div class="picker-search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input class="picker-search-input" type="search" placeholder="Your library, or search everything..."
                   value="@_search" @oninput="OnSearchInput" autofocus />
        </div>
        <div class="picker-list">
            @if (_searching)
            {
                <div class="picker-hint">Searching...</div>
            }
            @foreach (var g in PickerEntries)
            {
                var entry = g;
                <button class="picker-item" @onclick="() => SelectGame(entry)">
                    <div class="picker-item-art" style="@(entry.ArtUrl != null ? $"background-image:url('{entry.ArtUrl}')" : $"background:{GameVisuals.Gradient(entry.Genre)}")"></div>
                    <div class="picker-item-info">
                        <span class="picker-item-name">@entry.Name</span>
                        <span class="picker-item-dev">@(entry.Genre ?? "Game")@(entry.FromLibrary ? " · In your library" : "")</span>
                    </div>
                    @if (entry.Score is double sc and > 0)
                    {
                        <span class="picker-item-score">@sc.ToString("F1")</span>
                    }
                </button>
            }
            @if (!_searching && !PickerEntries.Any())
            {
                <div class="picker-hint">
                    @(string.IsNullOrWhiteSpace(_search)
                        ? "Your library is empty — type to search the full catalog"
                        : "No matches — keep typing to search the catalog")
                </div>
            }
        </div>
    </div>
}

@code {
    private record PickEntry(string Name, string? ArtUrl, string? Genre, double? Score, bool FromLibrary);

    private readonly PickEntry?[] _slots = new PickEntry?[3];
    private List<Games> _library = new();
    private bool _pickerOpen;
    private int  _pickerTarget;
    private string _search = "";
    private bool _searching;
    private int _searchToken;
    private List<PickEntry> _searchResults = new();

    private IEnumerable<PickEntry> PickerEntries
    {
        get
        {
            var fromLibrary = _library
                .Where(g => g.Name != null &&
                            (string.IsNullOrWhiteSpace(_search) ||
                             g.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)))
                .OrderByDescending(g => g.Review)
                .Select(g => new PickEntry(g.Name!, g.GameArtUrl, g.Genre, g.Review, true))
                .ToList();

            var libraryNames = fromLibrary.Select(e => e.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
            return fromLibrary.Concat(_searchResults.Where(r => !libraryNames.Contains(r.Name)));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser == null) return;

        _library = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);
        var saved = await Firebase.GetTop3Async(AuthState.CurrentUser.Uid);

        for (int i = 0; i < 3 && i < saved.Count; i++)
        {
            var name = saved[i];
            if (name == null) continue;

            var inLib = _library.FirstOrDefault(g =>
                string.Equals(g.Name, name, StringComparison.OrdinalIgnoreCase));
            _slots[i] = inLib != null
                ? new PickEntry(inLib.Name!, inLib.GameArtUrl, inLib.Genre, inLib.Review, true)
                : new PickEntry(name, null, null, null, false);
        }
        StateHasChanged();

        // Backfill missing art (saved names that aren't in the library)
        for (int i = 0; i < 3; i++)
        {
            var slot = _slots[i];
            if (slot != null && slot.ArtUrl == null)
            {
                var art = await RawgService.GetGameArtAsync(slot.Name);
                if (art != null) _slots[i] = slot with { ArtUrl = art };
            }
        }
        StateHasChanged();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        var token = ++_searchToken;

        if (string.IsNullOrWhiteSpace(_search))
        {
            _searchResults = new();
            _searching = false;
            return;
        }

        await Task.Delay(350);
        if (token != _searchToken) return;

        _searching = true;
        StateHasChanged();

        var res = await RawgService.SearchGamesAsync(_search);
        if (token != _searchToken) return;

        _searchResults = res.Select(r => new PickEntry(r.Name, r.ArtUrl, r.Genre, null, false)).ToList();
        _searching = false;
        StateHasChanged();
    }

    private void OpenPicker(int idx)
    {
        _pickerTarget = idx;
        _search = "";
        _searchResults = new();
        _pickerOpen = true;
    }

    private void ClosePicker() => _pickerOpen = false;

    private async Task SelectGame(PickEntry entry)
    {
        _slots[_pickerTarget] = entry;
        _pickerOpen = false;
        await SaveTop3();
        await Xp.AwardAsync(XpAction.Top3, entry.Name);
    }

    private async Task RemoveSlot(int idx)
    {
        _slots[idx] = null;
        await SaveTop3();
    }

    private async Task SaveTop3()
    {
        if (AuthState.CurrentUser != null)
            await Firebase.SaveTop3Async(AuthState.CurrentUser.Uid,
                _slots.Select(s => s?.Name).ToList());
    }
}
