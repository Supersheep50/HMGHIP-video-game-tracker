@page "/top3"
@inject PlayedGames.Services.RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState
@inject XpService Xp

<PageTitle>Top 3 — HMGHIP</PageTitle>

<div class="hero-header">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">All Time</div>
            <p class="hero-title">My Top 3</p>
            <p class="hero-subtitle">The three games I'd take to a desert island</p>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <div class="top3-grid">
        @for (int i = 0; i < 3; i++)
        {
            var idx = i;
            var slot = _slots[idx];
            <div class="top3-slot @(slot == null ? "top3-slot-empty" : "")" @onclick="() => OpenPicker(idx)">
                @if (slot == null)
                {
                    <div class="top3-rank">#@(idx + 1)</div>
                    <svg class="top3-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                    </svg>
                    <span class="top3-add-label">Add Game</span>
                }
                else
                {
                    <div class="top3-art" style="@(slot.GameArtUrl != null ? $"background-image:url('{slot.GameArtUrl}')" : $"background:{GetGenreGradient(slot.Genre)}")"></div>
                    <div class="top3-info-overlay">
                        <span class="top3-rank-badge">#@(idx + 1)</span>
                        <p class="top3-game-name">@slot.Name</p>
                        <p class="top3-game-score">@slot.Review.ToString("F1")<span class="top3-score-sub">/10</span></p>
                    </div>
                    <button class="top3-remove" @onclick:stopPropagation @onclick="() => RemoveSlot(idx)">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                    </button>
                }
            </div>
        }
    </div>

</MudContainer>

@if (_pickerOpen)
{
    <div class="picker-backdrop" @onclick="ClosePicker"></div>
    <div class="picker-sheet">
        <div class="drawer-handle-bar"></div>
        <div class="picker-header">
            <span class="picker-title">Choose a Game</span>
        </div>
        <div class="picker-search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input class="picker-search-input" type="search" placeholder="Search games..." @bind="_search" @bind:event="oninput" autofocus />
        </div>
        <div class="picker-list">
            @foreach (var game in PickerGames)
            {
                var g = game;
                <button class="picker-item" @onclick="() => SelectGame(g)">
                    <div class="picker-item-art" style="@(g.GameArtUrl != null ? $"background-image:url('{g.GameArtUrl}')" : $"background:{GetGenreGradient(g.Genre)}")"></div>
                    <div class="picker-item-info">
                        <span class="picker-item-name">@g.Name</span>
                        <span class="picker-item-dev">@g.Developer</span>
                    </div>
                    <span class="picker-item-score">@g.Review.ToString("F1")</span>
                </button>
            }
        </div>
    </div>
}

