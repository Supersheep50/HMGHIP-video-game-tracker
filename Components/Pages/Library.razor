@page "/library"
@implements IDisposable
@inject RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState
@inject GameStateService GameState

<PageTitle>Games Library — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">All Time</div>
            <p class="hero-title">Games Library</p>
            <p class="hero-subtitle">Every game, every year — the complete record</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card anim-fade-up anim-delay-2">
                <span class="stat-number">@_savedGames.Count</span>
                <span class="stat-label">Games</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-3">
                <span class="stat-number">@_savedGames.Sum(g => g.HoursPlayed).ToString("N0")</span>
                <span class="stat-label">Hours</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-4">
                <span class="stat-number">@(_savedGames.Any(g => g.Review > 0) ? _savedGames.Where(g => g.Review > 0).Average(g => g.Review).ToString("F1") : "—")</span>
                <span class="stat-label">Avg Score</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <MudTextField @bind-Value="_searchQuery"
                  Placeholder="Search for a game to add to your library..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Immediate="true"
                  DebounceInterval="500"
                  OnDebounceIntervalElapsed="SearchGames"
                  Class="library-search"
                  FullWidth="true" />

    @if (_isSearching)
    {
        <div class="search-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            <span>Searching...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_searchQuery))
    {
        @if (_searchResults.Any())
        {
            <MudText Typo="Typo.body2" Class="results-count">
                @_searchResults.Count results for "@_searchQuery"
            </MudText>
            <MudGrid Spacing="3">
                @foreach (var result in _searchResults)
                {
                    var saved = _savedGames.FirstOrDefault(g => string.Equals(g.Name, result.Name, StringComparison.OrdinalIgnoreCase));
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Class="game-card" Elevation="0">
                            <div class="card-art" style="background: @GameVisuals.Gradient(result.Genre)">
                                @if (!string.IsNullOrEmpty(result.ArtUrl))
                                {
                                    <img src="@result.ArtUrl" class="card-art-img" alt="@result.Name" />
                                }
                                else
                                {
                                    <div class="card-art-icon">
                                        <MudIcon Icon="@GameVisuals.Icon(result.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                                    </div>
                                }
                            </div>
                            <MudCardContent Class="card-body">
                                <div class="card-title-row">
                                    <p class="game-name">@result.Name</p>
                                    @if (saved?.Review > 0)
                                    {
                                        <span class="card-score @GameVisuals.RatingClass(saved.Review)">@saved.Review.ToString("F1")<span class="card-score-sub">/10</span></span>
                                    }
                                </div>
                                @if (saved?.Review > 0)
                                {
                                    <div class="card-stars-wrap">@GameVisuals.Stars(saved.Review)</div>
                                }
                                <div class="card-tags">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@(result.Genre ?? "Game")</MudChip>
                                </div>
                            </MudCardContent>
                            <div class="card-actions">
                                <button class="card-action-btn card-action-want @(_wantToPlay.Contains(result.Name) ? "action-active" : "")"
                                        @onclick="() => GameState.RequestOpenGame(result.Name, result.ArtUrl, result.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                                    Want
                                </button>
                                <button class="card-action-btn card-action-playing @(_playing.Contains(result.Name) ? "action-active" : "")"
                                        @onclick="() => GameState.RequestOpenGame(result.Name, result.ArtUrl, result.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    Playing
                                </button>
                                <button class="card-action-btn card-action-finished @(_finished.Contains(result.Name) ? "action-active" : "")"
                                        @onclick='() => GameState.RequestOpenGame(result.Name, result.ArtUrl, result.Genre, "finished")'>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    Finished
                                </button>
                                <button class="card-action-btn card-action-review @(saved?.Review > 0 ? "action-active" : "")"
                                        @onclick='() => GameState.RequestOpenGame(result.Name, result.ArtUrl, result.Genre, "review")'>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                    Review
                                </button>
                            </div>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">No results for "@_searchQuery"</MudText>
            </div>
        }
    }
    else
    {
        @if (AuthState.CurrentUser == null)
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">Sign in to see your library</MudText>
            </div>
        }
        else if (!_savedGames.Any())
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">Your library is empty</MudText>
                <MudText Typo="Typo.body2">Search for a game above to get started</MudText>
            </div>
        }
        else
        {
            <div class="status-filter-row">
                <button class="status-filter-chip @(_filter == "all" ? "chip-active" : "")" @onclick='() => _filter = "all"'>
                    All <span class="chip-count">@_savedGames.Count</span>
                </button>
                <button class="status-filter-chip chip-playing @(_filter == "playing" ? "chip-active" : "")" @onclick='() => _filter = "playing"'>
                    Playing <span class="chip-count">@_savedGames.Count(g => g.Name != null && _playing.Contains(g.Name))</span>
                </button>
                <button class="status-filter-chip chip-want @(_filter == "want" ? "chip-active" : "")" @onclick='() => _filter = "want"'>
                    Want to Play <span class="chip-count">@_savedGames.Count(g => g.Name != null && _wantToPlay.Contains(g.Name))</span>
                </button>
                <button class="status-filter-chip chip-finished @(_filter == "finished" ? "chip-active" : "")" @onclick='() => _filter = "finished"'>
                    Finished <span class="chip-count">@_savedGames.Count(g => g.Name != null && _finished.Contains(g.Name))</span>
                </button>
                <button class="status-filter-chip chip-reviewed @(_filter == "reviewed" ? "chip-active" : "")" @onclick='() => _filter = "reviewed"'>
                    Reviewed <span class="chip-count">@_savedGames.Count(g => g.Review > 0)</span>
                </button>
            </div>

            @if (!FilteredGames.Any())
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Style="font-size: 4rem; opacity: 0.3;" />
                    <MudText Typo="Typo.h6" Class="mt-3">Nothing here yet</MudText>
                    <MudText Typo="Typo.body2">Games you mark will show up under this filter</MudText>
                </div>
            }
            <MudGrid Spacing="3">
                @{ int cardIdx = 0; }
                @foreach (var game in FilteredGames.OrderByDescending(g => g.Review).ThenBy(g => g.Name))
                {
                    var delay = $"animation-delay:{cardIdx * 0.07}s";
                    cardIdx++;
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <div class="card-reveal" style="@delay">
                        <MudCard Class="game-card" Elevation="0">
                            <div class="card-art @(game.GameArtUrl == null ? "card-art-loading" : "")"
                                 style="background: @GameVisuals.Gradient(game.Genre)">
                                @if (!string.IsNullOrEmpty(game.GameArtUrl))
                                {
                                    <img src="@game.GameArtUrl" class="card-art-img" alt="@game.Name" />
                                }
                                else
                                {
                                    <div class="card-art-icon">
                                        <MudIcon Icon="@GameVisuals.Icon(game.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                                    </div>
                                }
                            </div>
                            <MudCardContent Class="card-body">
                                <div class="card-title-row">
                                    <p class="game-name">@game.Name</p>
                                    @if (game.Review > 0)
                                    {
                                        <span class="card-score @GameVisuals.RatingClass(game.Review)">@game.Review.ToString("F1")<span class="card-score-sub">/10</span></span>
                                    }
                                </div>
                                @if (game.Review > 0)
                                {
                                    <div class="card-stars-wrap">@GameVisuals.Stars(game.Review)</div>
                                }
                                @if (game.HoursPlayed > 0)
                                {
                                    <div class="card-info-row">
                                        <div class="card-played">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="hours-icon" />
                                            <span class="hours-text">@game.HoursPlayed hrs played</span>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(game.ReviewText))
                                {
                                    <p class="card-review-snippet">@game.ReviewText</p>
                                }
                                <div class="card-tags">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@(game.Genre ?? "Game")</MudChip>
                                </div>
                            </MudCardContent>
                            <div class="card-actions">
                                <button class="card-action-btn card-action-want @(_wantToPlay.Contains(game.Name!) ? "action-active" : "")"
                                        @onclick="() => GameState.RequestOpenGame(game.Name!, game.GameArtUrl, game.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                                    Want
                                </button>
                                <button class="card-action-btn card-action-playing @(_playing.Contains(game.Name!) ? "action-active" : "")"
                                        @onclick="() => GameState.RequestOpenGame(game.Name!, game.GameArtUrl, game.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    Playing
                                </button>
                                <button class="card-action-btn card-action-finished @(_finished.Contains(game.Name!) ? "action-active" : "")"
                                        @onclick='() => GameState.RequestOpenGame(game.Name!, game.GameArtUrl, game.Genre, "finished")'>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    Finished
                                </button>
                                <button class="card-action-btn card-action-review @(game.Review > 0 ? "action-active" : "")"
                                        @onclick='() => GameState.RequestOpenGame(game.Name!, game.GameArtUrl, game.Genre, "review")'>
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                    Review
                                </button>
                            </div>
                        </MudCard>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        }
    }

</MudContainer>

@code {
    private List<Games> _savedGames = new();
    private List<RawgSearchResult> _searchResults = new();
    private string _searchQuery = "";
    private bool _isSearching;

    private readonly HashSet<string> _playing    = new();
    private readonly HashSet<string> _finished   = new();
    private readonly HashSet<string> _wantToPlay = new();

    protected override async Task OnInitializedAsync()
    {
        GameState.OnChanged += OnGamesChanged;
        AuthState.OnChange  += OnAuthChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (AuthState.CurrentUser == null) return;

        _savedGames = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);

        _playing.Clear();
        _finished.Clear();
        _wantToPlay.Clear();
        var statuses = await Firebase.GetGameStatusesAsync(AuthState.CurrentUser.Uid);
        foreach (var (name, status) in statuses)
        {
            if (status == "playing")           _playing.Add(name);
            else if (status == "finished")     _finished.Add(name);
            else if (status == "want_to_play") _wantToPlay.Add(name);
        }
    }

    private async void OnGamesChanged()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthChanged()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GameState.OnChanged -= OnGamesChanged;
        AuthState.OnChange  -= OnAuthChanged;
    }

    // ── Search ────────────────────────────────────────────────────────────

    private async Task SearchGames(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            _searchResults = new();
            return;
        }
        _isSearching = true;
        StateHasChanged();
        _searchResults = await RawgService.SearchGamesAsync(query);
        _isSearching = false;
    }

    // ── Status filter ─────────────────────────────────────────────────────

    private string _filter = "all";

    private IEnumerable<Games> FilteredGames => _filter switch
    {
        "playing"  => _savedGames.Where(g => g.Name != null && _playing.Contains(g.Name)),
        "want"     => _savedGames.Where(g => g.Name != null && _wantToPlay.Contains(g.Name)),
        "finished" => _savedGames.Where(g => g.Name != null && _finished.Contains(g.Name)),
        "reviewed" => _savedGames.Where(g => g.Review > 0),
        _          => _savedGames,
    };
}
