@page "/library"
@inject RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState

<PageTitle>Games Library — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">All Time</div>
            <p class="hero-title">Games Library</p>
            <p class="hero-subtitle">Every game, every year — the complete record</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card anim-fade-up anim-delay-2">
                <span class="stat-number">@_savedGames.Count</span>
                <span class="stat-label">Games</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-3">
                <span class="stat-number">@_savedGames.Sum(g => g.HoursPlayed).ToString("N0")</span>
                <span class="stat-label">Hours</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-4">
                <span class="stat-number">@(_savedGames.Any(g => g.Review > 0) ? _savedGames.Where(g => g.Review > 0).Average(g => g.Review).ToString("F1") : "—")</span>
                <span class="stat-label">Avg Score</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <MudTextField @bind-Value="_searchQuery"
                  Placeholder="Search for a game to add to your library..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Immediate="true"
                  DebounceInterval="500"
                  OnDebounceIntervalElapsed="SearchGames"
                  Class="library-search"
                  FullWidth="true" />

    @if (_isSearching)
    {
        <div class="search-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            <span>Searching...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_searchQuery))
    {
        @if (_searchResults.Any())
        {
            <MudText Typo="Typo.body2" Class="results-count">
                @_searchResults.Count results for "@_searchQuery"
            </MudText>
            <MudGrid Spacing="3">
                @foreach (var result in _searchResults)
                {
                    var saved = _savedGames.FirstOrDefault(g => string.Equals(g.Name, result.Name, StringComparison.OrdinalIgnoreCase));
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Class="game-card" Elevation="0">
                            <div class="card-art" style="background: @GetGenreGradient(result.Genre)">
                                @if (!string.IsNullOrEmpty(result.ArtUrl))
                                {
                                    <img src="@result.ArtUrl" class="card-art-img" alt="@result.Name" />
                                }
                                else
                                {
                                    <div class="card-art-icon">
                                        <MudIcon Icon="@GetGenreIcon(result.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                                    </div>
                                }
                            </div>
                            <MudCardContent Class="card-body">
                                <div class="card-title-row">
                                    <p class="game-name">@result.Name</p>
                                    @if (saved?.Review > 0)
                                    {
                                        <span class="card-score @GetRatingClass(saved.Review)">@saved.Review.ToString("F1")<span class="card-score-sub">/10</span></span>
                                    }
                                </div>
                                @if (saved?.Review > 0)
                                {
                                    <div class="card-stars-wrap">@RenderStars(saved.Review)</div>
                                }
                                <div class="card-tags">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@(result.Genre ?? "Game")</MudChip>
                                </div>
                            </MudCardContent>
                            <div class="card-actions">
                                <button class="card-action-btn card-action-playing @(_playing.Contains(result.Name) ? "action-active" : "")"
                                        @onclick="() => TogglePlaying(result.Name, result.ArtUrl, result.Genre)">
                                    @if (_playing.Contains(result.Name)) {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    } else {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    }
                                    Playing
                                </button>
                                <button class="card-action-btn card-action-finished @(_finished.Contains(result.Name) ? "action-active" : "")"
                                        @onclick="() => HandleFinishedClick(result.Name, result.ArtUrl, result.Genre)">
                                    @if (_finished.Contains(result.Name)) {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    } else {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    }
                                    Finished
                                </button>
                                <button class="card-action-btn card-action-review @(saved?.Review > 0 ? "action-active" : "")"
                                        @onclick="() => OpenReviewPopup(result.Name, result.ArtUrl, result.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                    Review
                                </button>
                            </div>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">No results for "@_searchQuery"</MudText>
            </div>
        }
    }
    else
    {
        @if (AuthState.CurrentUser == null)
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">Sign in to see your library</MudText>
            </div>
        }
        else if (!_savedGames.Any())
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="font-size: 4rem; opacity: 0.3;" />
                <MudText Typo="Typo.h6" Class="mt-3">Your library is empty</MudText>
                <MudText Typo="Typo.body2">Search for a game above to get started</MudText>
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="results-count">
                @_savedGames.Count games
            </MudText>
            <MudGrid Spacing="3">
                @{ int cardIdx = 0; }
                @foreach (var game in _savedGames.OrderByDescending(g => g.Review).ThenBy(g => g.Name))
                {
                    var delay = $"animation-delay:{cardIdx * 0.07}s";
                    cardIdx++;
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <div class="card-reveal" style="@delay">
                        <MudCard Class="game-card" Elevation="0">
                            <div class="card-art @(game.GameArtUrl == null ? "card-art-loading" : "")"
                                 style="background: @GetGenreGradient(game.Genre)">
                                @if (!string.IsNullOrEmpty(game.GameArtUrl))
                                {
                                    <img src="@game.GameArtUrl" class="card-art-img" alt="@game.Name" />
                                }
                                else
                                {
                                    <div class="card-art-icon">
                                        <MudIcon Icon="@GetGenreIcon(game.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                                    </div>
                                }
                            </div>
                            <MudCardContent Class="card-body">
                                <div class="card-title-row">
                                    <p class="game-name">@game.Name</p>
                                    @if (game.Review > 0)
                                    {
                                        <span class="card-score @GetRatingClass(game.Review)">@game.Review.ToString("F1")<span class="card-score-sub">/10</span></span>
                                    }
                                </div>
                                @if (game.Review > 0)
                                {
                                    <div class="card-stars-wrap">@RenderStars(game.Review)</div>
                                }
                                @if (game.HoursPlayed > 0)
                                {
                                    <div class="card-info-row">
                                        <div class="card-played">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="hours-icon" />
                                            <span class="hours-text">@game.HoursPlayed hrs played</span>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(game.ReviewText))
                                {
                                    <p class="card-review-snippet">@game.ReviewText</p>
                                }
                                <div class="card-tags">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@(game.Genre ?? "Game")</MudChip>
                                </div>
                            </MudCardContent>
                            <div class="card-actions">
                                <button class="card-action-btn card-action-playing @(_playing.Contains(game.Name!) ? "action-active" : "")"
                                        @onclick="() => TogglePlaying(game.Name!, game.GameArtUrl, game.Genre)">
                                    @if (_playing.Contains(game.Name!)) {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    } else {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    }
                                    Playing
                                </button>
                                <button class="card-action-btn card-action-finished @(_finished.Contains(game.Name!) ? "action-active" : "")"
                                        @onclick="() => HandleFinishedClick(game.Name!, game.GameArtUrl, game.Genre)">
                                    @if (_finished.Contains(game.Name!)) {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    } else {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                    }
                                    Finished
                                </button>
                                <button class="card-action-btn card-action-review @(game.Review > 0 ? "action-active" : "")"
                                        @onclick="() => OpenReviewPopup(game.Name!, game.GameArtUrl, game.Genre)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                    Review
                                </button>
                            </div>
                        </MudCard>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        }
    }

</MudContainer>

@if (_finishedGame != null)
{
    <div class="popup-overlay" @onclick="CloseFinishedPopup">
        <div class="popup-sheet" @onclick:stopPropagation>
            <div class="popup-handle-bar"></div>
            <p class="popup-title">Mark as Finished</p>
            <p class="popup-game-name">@_finishedGame</p>
            <MudNumericField @bind-Value="_finishedHours" Label="Hours Played" Variant="Variant.Outlined"
                             Min="0.0" Step="0.5" Class="mb-4" FullWidth="true" />
            <div class="popup-actions">
                <MudButton Variant="Variant.Text" OnClick="CloseFinishedPopup">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitFinished">Save</MudButton>
            </div>
        </div>
    </div>
}

@if (_reviewGame != null)
{
    <div class="popup-overlay" @onclick="CloseReviewPopup">
        <div class="popup-sheet" @onclick:stopPropagation>
            <div class="popup-handle-bar"></div>
            <p class="popup-title">Write a Review</p>
            <p class="popup-game-name">@_reviewGame</p>
            <div class="star-rating-row">
                <MudRating @bind-SelectedValue="_reviewStars" MaxValue="5" Color="Color.Warning" />
                <span class="star-score-label">@(_reviewStars * 2) / 10</span>
            </div>
            <MudTextField @bind-Value="_reviewText" Label="Your thoughts..." Lines="4"
                          Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
            <div class="popup-actions">
                <MudButton Variant="Variant.Text" OnClick="CloseReviewPopup">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SubmitReview" Disabled="@(_reviewStars == 0)">
                    Save Review
                </MudButton>
            </div>
        </div>
    </div>
}

@code {
    private List<Games> _savedGames = new();
    private List<RawgSearchResult> _searchResults = new();
    private string _searchQuery = "";
    private bool _isSearching;

    private readonly HashSet<string> _playing  = new();
    private readonly HashSet<string> _finished = new();

    // Finished popup
    private string? _finishedGame;
    private string? _finishedGameArt;
    private string? _finishedGameGenre;
    private double  _finishedHours;

    // Review popup
    private string? _reviewGame;
    private string? _reviewGameArt;
    private string? _reviewGameGenre;
    private int     _reviewStars = 3;
    private string  _reviewText  = "";

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CurrentUser == null) return;

        _savedGames = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);

        var statuses = await Firebase.GetGameStatusesAsync(AuthState.CurrentUser.Uid);
        foreach (var (name, status) in statuses)
        {
            if (status == "playing")       _playing.Add(name);
            else if (status == "finished") _finished.Add(name);
        }
    }

    // ── Search ────────────────────────────────────────────────────────────

    private async Task SearchGames(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            _searchResults = new();
            return;
        }
        _isSearching = true;
        StateHasChanged();
        _searchResults = await RawgService.SearchGamesAsync(query);
        _isSearching = false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    private Games GetOrCreate(string name, string? artUrl, string? genre)
    {
        var existing = _savedGames.FirstOrDefault(g =>
            string.Equals(g.Name, name, StringComparison.OrdinalIgnoreCase));
        if (existing != null) return existing;

        var game = new Games { Name = name, GameArtUrl = artUrl, Genre = genre ?? "Other", Year = DateTime.Now.Year };
        _savedGames.Add(game);
        return game;
    }

    // ── Playing ───────────────────────────────────────────────────────────

    private async Task TogglePlaying(string name, string? artUrl, string? genre)
    {
        GetOrCreate(name, artUrl, genre);

        if (!_playing.Add(name)) _playing.Remove(name);
        else _finished.Remove(name);

        if (AuthState.CurrentUser != null)
        {
            var status = _playing.Contains(name) ? "playing" : "none";
            await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, name, status);
            await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, _savedGames);
        }
    }

    // ── Finished ──────────────────────────────────────────────────────────

    private async Task HandleFinishedClick(string name, string? artUrl, string? genre)
    {
        if (_finished.Contains(name))
        {
            _finished.Remove(name);
            if (AuthState.CurrentUser != null)
                await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, name, "none");
        }
        else
        {
            var existing = _savedGames.FirstOrDefault(g =>
                string.Equals(g.Name, name, StringComparison.OrdinalIgnoreCase));
            _finishedGame    = name;
            _finishedGameArt = artUrl;
            _finishedGameGenre = genre;
            _finishedHours   = existing?.HoursPlayed ?? 0;
        }
    }

    private void CloseFinishedPopup() => _finishedGame = null;

    private async Task SubmitFinished()
    {
        if (_finishedGame == null) return;

        var game = GetOrCreate(_finishedGame, _finishedGameArt, _finishedGameGenre);
        game.HoursPlayed = _finishedHours;

        _finished.Add(_finishedGame);
        _playing.Remove(_finishedGame);

        if (AuthState.CurrentUser != null)
        {
            await Firebase.SaveGameStatusAsync(AuthState.CurrentUser.Uid, _finishedGame, "finished");
            await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, _savedGames);
        }

        CloseFinishedPopup();
    }

    // ── Review ────────────────────────────────────────────────────────────

    private void OpenReviewPopup(string name, string? artUrl, string? genre)
    {
        var existing = _savedGames.FirstOrDefault(g =>
            string.Equals(g.Name, name, StringComparison.OrdinalIgnoreCase));
        _reviewGame    = name;
        _reviewGameArt = artUrl;
        _reviewGameGenre = genre;
        _reviewStars   = existing?.Review > 0 ? (int)Math.Round(existing.Review / 2.0) : 3;
        _reviewText    = existing?.ReviewText ?? "";
    }

    private void CloseReviewPopup() => _reviewGame = null;

    private async Task SubmitReview()
    {
        if (_reviewGame == null) return;

        var game = GetOrCreate(_reviewGame, _reviewGameArt, _reviewGameGenre);
        game.Review     = _reviewStars * 2.0;
        game.ReviewText = _reviewText;

        if (AuthState.CurrentUser != null)
            await Firebase.SaveGamesAsync(AuthState.CurrentUser.Uid, _savedGames);

        CloseReviewPopup();
    }

    // ── Display helpers ───────────────────────────────────────────────────

    private static MarkupString RenderStars(double score)
    {
        double stars = score / 2.0;
        int full  = (int)Math.Floor(stars);
        bool half = (stars - full) >= 0.5;
        int empty = 5 - full - (half ? 1 : 0);
        const string F = "<svg class='star star-full'  viewBox='0 0 24 24'><path d='M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z'/></svg>";
        const string H = "<svg class='star star-half'  viewBox='0 0 24 24'><path d='M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4V6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z'/></svg>";
        const string E = "<svg class='star star-empty' viewBox='0 0 24 24'><path d='M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z'/></svg>";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < full;  i++) sb.Append(F);
        if (half) sb.Append(H);
        for (int i = 0; i < empty; i++) sb.Append(E);
        return new MarkupString(sb.ToString());
    }

    private string GetRatingClass(double r) => r switch
    {
        >= 9 => "rating-excellent",
        >= 7 => "rating-good",
        >= 5 => "rating-average",
        _    => "rating-poor"
    };

    private string GetGenreGradient(string? genre) => genre switch
    {
        "Action RPG"       => "linear-gradient(145deg, #1e0a3c 0%, #6b21a8 100%)",
        "RPG"              => "linear-gradient(145deg, #0d1b4b 0%, #1d4ed8 100%)",
        "Action-Adventure" => "linear-gradient(145deg, #1c0505 0%, #991b1b 100%)",
        "JRPG"             => "linear-gradient(145deg, #3b0000 0%, #dc2626 100%)",
        "Roguelike"        => "linear-gradient(145deg, #0a0a1a 0%, #4338ca 100%)",
        "Metroidvania"     => "linear-gradient(145deg, #000d10 0%, #0e7490 100%)",
        "Simulation"       => "linear-gradient(145deg, #0a1a0a 0%, #15803d 100%)",
        "MMORPG"           => "linear-gradient(145deg, #1a1000 0%, #b45309 100%)",
        "Action"           => "linear-gradient(145deg, #1a0a00 0%, #c2410c 100%)",
        "Platformer"       => "linear-gradient(145deg, #0a1a2a 0%, #0369a1 100%)",
        "Racing"           => "linear-gradient(145deg, #1a0a00 0%, #d97706 100%)",
        _                  => "linear-gradient(145deg, #1a1a2e 0%, #374151 100%)",
    };

    private string GetGenreIcon(string? genre) => genre switch
    {
        "Action RPG"       => Icons.Material.Filled.AutoFixHigh,
        "RPG"              => Icons.Material.Filled.AutoAwesome,
        "Action-Adventure" => Icons.Material.Filled.Explore,
        "JRPG"             => Icons.Material.Filled.Stars,
        "Roguelike"        => Icons.Material.Filled.Loop,
        "Metroidvania"     => Icons.Material.Filled.Terrain,
        "Simulation"       => Icons.Material.Filled.Yard,
        "MMORPG"           => Icons.Material.Filled.Groups,
        "Action"           => Icons.Material.Filled.FlashOn,
        "Platformer"       => Icons.Material.Filled.DirectionsRun,
        "Racing"           => Icons.Material.Filled.Speed,
        _                  => Icons.Material.Filled.SportsEsports,
    };
}
