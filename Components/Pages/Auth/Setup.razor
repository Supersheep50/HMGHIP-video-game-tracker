        new Games { Name = "The Witcher 3: Wild Hunt",                  Genre = "RPG",              System = "PC",              Developer = "CD Projekt Red",         HoursPlayed = 180, Review = 10.0, HowLongToBeat = 52  },
        new Games { Name = "God of War",                                Genre = "Action-Adventure", System = "PlayStation 4",   Developer = "Santa Monica Studio",    HoursPlayed = 75,  Review = 9.5,  HowLongToBeat = 21  },
        new Games { Name = "Red Dead Redemption 2",                     Genre = "Action-Adventure", System = "PlayStation 4",   Developer = "Rockstar Games",         HoursPlayed = 110, Review = 9.5,  HowLongToBeat = 50  },
        new Games { Name = "Hollow Knight",                             Genre = "Metroidvania",     System = "PC",              Developer = "Team Cherry",            HoursPlayed = 45,  Review = 9.0,  HowLongToBeat = 42  },
        new Games { Name = "Hades",                                     Genre = "Roguelike",        System = "PC",              Developer = "Supergiant Games",       HoursPlayed = 55,  Review = 9.5,  HowLongToBeat = 22  },
        new Games { Name = "Persona 5 Royal",                           Genre = "JRPG",             System = "PlayStation 4",   Developer = "Atlus",                  HoursPlayed = 120, Review = 10.0, HowLongToBeat = 103 },
        new Games { Name = "Breath of the Wild",                        Genre = "Action-Adventure", System = "Nintendo Switch", Developer = "Nintendo",               HoursPlayed = 150, Review = 10.0, HowLongToBeat = 50  },
        new Games { Name = "Disco Elysium",                             Genre = "RPG",              System = "PC",              Developer = "ZA/UM",                  HoursPlayed = 38,  Review = 9.0,  HowLongToBeat = 25  },
        new Games { Name = "Mass Effect 2",                             Genre = "RPG",              System = "PC",              Developer = "BioWare",                HoursPlayed = 42,  Review = 10.0, HowLongToBeat = 25  },
        new Games { Name = "Bloodborne",                                Genre = "Action RPG",       System = "PlayStation 4",   Developer = "FromSoftware",           HoursPlayed = 60,  Review = 9.5,  HowLongToBeat = 35  },
        new Games { Name = "Divinity: Original Sin 2",                  Genre = "RPG",              System = "PC",              Developer = "Larian Studios",         HoursPlayed = 160, Review = 9.5,  HowLongToBeat = 60  },
        new Games { Name = "Final Fantasy XIV",                         Genre = "MMORPG",           System = "PC",              Developer = "Square Enix",            HoursPlayed = 300, Review = 9.0,  HowLongToBeat = 120 },
        new Games { Name = "It Takes Two",                              Genre = "Action",           System = "PC",              Developer = "Hazelight Studios",      HoursPlayed = 12,  Review = 9.5,  HowLongToBeat = 12  },
        new Games { Name = "Ghost of Tsushima",                         Genre = "Action-Adventure", System = "PlayStation 4",   Developer = "Sucker Punch",           HoursPlayed = 50,  Review = 9.0,  HowLongToBeat = 26  },
        new Games { Name = "Hades",                                     Genre = "Roguelike",        System = "PC",              Developer = "Supergiant Games",       HoursPlayed = 55,  Review = 9.5,  HowLongToBeat = 22  },
        new Games { Name = "Sekiro: Shadows Die Twice",                 Genre = "Action",           System = "PC",              Developer = "FromSoftware",           HoursPlayed = 65,  Review = 8.5,  HowLongToBeat = 30  },
        new Games { Name = "Stardew Valley",                            Genre = "Simulation",       System = "PC",              Developer = "ConcernedApe",           HoursPlayed = 130, Review = 8.5,  HowLongToBeat = 55  },
        new Games { Name = "Cyberpunk 2077",                            Genre = "RPG",              System = "PC",              Developer = "CD Projekt Red",         HoursPlayed = 85,  Review = 8.0,  HowLongToBeat = 25  },
        new Games { Name = "Returnal",                                  Genre = "Roguelike",        System = "PlayStation 5",   Developer = "Housemarque",            HoursPlayed = 35,  Review = 8.5,  HowLongToBeat = 15  },
        new Games { Name = "Alan Wake 2",                               Genre = "Action-Adventure", System = "PC",              Developer = "Remedy Entertainment",   HoursPlayed = 20,  Review = 8.5,  HowLongToBeat = 15  },
        new Games { Name = "Vampire Survivors",                         Genre = "Roguelike",        System = "PC",              Developer = "Poncle",                 HoursPlayed = 25,  Review = 8.5,  HowLongToBeat = 10  },
    };

    protected override async Task OnInitializedAsync()
    {
        var tasks = _allGames.Select(async game =>
        {
            game.GameArtUrl = await RawgService.GetGameArtAsync(game.Name);
            await InvokeAsync(StateHasChanged);
        });
        await Task.WhenAll(tasks);
    }

    private IEnumerable<Games> PickerGames => _allGames
        .Where(g => string.IsNullOrWhiteSpace(_search) ||
                    (g.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(g => g.Review);

    private void GoToStep2()
    {
        _username = _username.Trim().ToLower().Replace(" ", "");
        if (_username.Length < 3) { _usernameError = "Username must be at least 3 characters"; return; }
        _usernameError = null;
        _step = 2;
    }

    private void OpenPicker(int idx) { _pickerTarget = idx; _search = ""; _pickerOpen = true; }

    private void SelectGame(Games game) { _slots[_pickerTarget] = game; _pickerOpen = false; }

    private async Task FinishSetup()
    {
        if (AuthState.CurrentUser == null) { Nav.NavigateTo("login", replace: true); return; }
        _saving = true;
        await Firebase.SaveProfileAsync(AuthState.CurrentUser.Uid, _username);
        var top3 = _slots.Select(s => s?.Name).ToList();
        if (top3.Any(t => t != null))
            await Firebase.SaveTop3Async(AuthState.CurrentUser.Uid, top3);
        Nav.NavigateTo("", replace: true);
    }

    private string GetGenreGradient(string? genre) => genre switch
    {
        "Action RPG"       => "linear-gradient(145deg, #1e0a3c 0%, #6b21a8 100%)",
        "RPG"              => "linear-gradient(145deg, #0d1b4b 0%, #1d4ed8 100%)",
        "Action-Adventure" => "linear-gradient(145deg, #1c0505 0%, #991b1b 100%)",
        "JRPG"             => "linear-gradient(145deg, #3b0000 0%, #dc2626 100%)",
        "Roguelike"        => "linear-gradient(145deg, #0a0a1a 0%, #4338ca 100%)",
        "Metroidvania"     => "linear-gradient(145deg, #000d10 0%, #0e7490 100%)",
        "Simulation"       => "linear-gradient(145deg, #0a1a0a 0%, #15803d 100%)",
        "MMORPG"           => "linear-gradient(145deg, #1a1000 0%, #b45309 100%)",
        "Action"           => "linear-gradient(145deg, #1a0a00 0%, #c2410c 100%)",
        "Platformer"       => "linear-gradient(145deg, #0a1a2a 0%, #0369a1 100%)",
        "Racing"           => "linear-gradient(145deg, #1a0a00 0%, #d97706 100%)",
        _                  => "linear-gradient(145deg, #1a1a2e 0%, #374151 100%)",
    };
}
