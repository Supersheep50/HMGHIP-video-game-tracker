@page "/setup"
@layout AuthLayout
@inject NavigationManager Nav
@inject AuthStateService AuthState
@inject FirebaseService Firebase
@inject PlayedGames.Services.RawgService RawgService

<PageTitle>Set Up Your Profile — HMGHIP</PageTitle>

<div class="setup-page">

    <!-- Step indicator -->
    <div class="setup-steps">
        <div class="setup-step @(_step >= 1 ? "step-active" : "")">1</div>
        <div class="setup-step-line"></div>
        <div class="setup-step @(_step >= 2 ? "step-active" : "")">2</div>
    </div>

    @if (_step == 1)
    {
        <!-- Step 1: Username -->
        <div class="setup-card anim-fade-up">
            @if (AuthState.CurrentUser?.PhotoUrl != null)
            {
                <img src="@AuthState.CurrentUser.PhotoUrl" class="setup-avatar" alt="avatar" />
            }
            <h1 class="setup-title">Welcome, @_firstName!</h1>
            <p class="setup-subtitle">Choose a username for your profile</p>

            <div class="setup-field">
                <span class="setup-field-prefix">@@</span>
                <input class="setup-input"
                       type="text"
                       placeholder="yourgamertag"
                       maxlength="20"
                       @bind="_username"
                       @bind:event="oninput" />
            </div>
            @if (_usernameError != null)
            {
                <p class="setup-error">@_usernameError</p>
            }

            <button class="setup-next-btn" @onclick="GoToStep2" disabled="@string.IsNullOrWhiteSpace(_username)">
                Next
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
            </button>
        </div>
    }
    else
    {
        <!-- Step 2: Top 3 -->
        <div class="setup-card anim-fade-up">
            <h1 class="setup-title">Pick Your Top 3</h1>
            <p class="setup-subtitle">Your all-time favourite games — you can change these any time</p>

            <div class="top3-grid" style="margin: 1.5rem 0;">
                @for (int i = 0; i < 3; i++)
                {
                    var idx = i;
                    var slot = _slots[idx];
                    <div class="top3-slot @(slot == null ? "top3-slot-empty" : "")" @onclick="() => OpenPicker(idx)">
                        @if (slot == null)
                        {
                            <div class="top3-rank">#@(idx + 1)</div>
                            <svg class="top3-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                            </svg>
                            <span class="top3-add-label">Add Game</span>
                        }
                        else
                        {
                            <div class="top3-art" style="@(slot.GameArtUrl != null ? $"background-image:url('{slot.GameArtUrl}')" : $"background:{GetGenreGradient(slot.Genre)}")"></div>
                            <div class="top3-info-overlay">
                                <span class="top3-rank-badge">#@(idx + 1)</span>
                                <p class="top3-game-name">@slot.Name</p>
                            </div>
                            <button class="top3-remove" @onclick:stopPropagation @onclick="() => _slots[idx] = null">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                            </button>
                        }
                    </div>
                }
            </div>

            <button class="setup-next-btn" @onclick="FinishSetup" disabled="@_saving">
                @(_saving ? "Saving..." : "Let's Go!")
                @if (!_saving)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
                }
            </button>
            <button class="setup-skip-btn" @onclick="FinishSetup">Skip for now</button>
        </div>
    }

</div>

@if (_pickerOpen)
{
    <div class="picker-backdrop" @onclick="() => _pickerOpen = false"></div>
    <div class="picker-sheet">
        <div class="drawer-handle-bar"></div>
        <div class="picker-header"><span class="picker-title">Choose a Game</span></div>
        <div class="picker-search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input class="picker-search-input" type="search" placeholder="Search games..." @bind="_search" @bind:event="oninput" autofocus />
        </div>
        <div class="picker-list">
            @foreach (var game in PickerGames)
            {
                var g = game;
                <button class="picker-item" @onclick="() => SelectGame(g)">
                    <div class="picker-item-art" style="@(g.GameArtUrl != null ? $"background-image:url('{g.GameArtUrl}')" : $"background:{GetGenreGradient(g.Genre)}")"></div>
                    <div class="picker-item-info">
                        <span class="picker-item-name">@g.Name</span>
                        <span class="picker-item-dev">@g.Developer</span>
                    </div>
                    <span class="picker-item-score">@g.Review.ToString("F1")</span>
                </button>
            }
        </div>
    </div>
}

@code {
    private string _firstName => AuthState.CurrentUser?.DisplayName?.Split(new[]{' '}, 2)[0] ?? "there";
    private int    _step          = 1;
    private string _username      = "";
    private string? _usernameError = null;
    private bool   _saving        = false;
    private bool   _pickerOpen    = false;
    private int    _pickerTarget  = 0;
    private string _search        = "";
    private readonly Games?[] _slots = new Games?[3];

    private readonly List<Games> _allGames = new()
    {
        new Games { Name = "Baldur's Gate 3",                           Genre = "RPG",              System = "PC",              Developer = "Larian Studios",         HoursPlayed = 120, Review = 10.0, HowLongToBeat = 100 },
