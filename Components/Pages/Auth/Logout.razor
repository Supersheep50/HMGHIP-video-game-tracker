@page "/logout"
@inject NavigationManager Nav

<PageTitle>Sign Out — HMGHIP</PageTitle>

<div class="auth-page">
    <div class="auth-card auth-card-narrow">

        <div class="auth-brand">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="#a78bfa" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5S19.33 12 18.5 12z"/>
            </svg>
            <span class="auth-brand-name">HMGHIP</span>
        </div>

        <h1 class="auth-title">Sign out?</h1>
        <p class="auth-subtitle">Your game diary will be here when you get back.</p>

        <div class="auth-form">
            <button class="auth-submit-btn auth-submit-danger" disabled>
                Sign Out
                <span class="auth-coming-soon-tag">Soon</span>
            </button>
            <button class="auth-cancel-btn" @onclick='() => Nav.NavigateTo("")'>
                Cancel — take me back
            </button>
        </div>

    </div>
</div>
