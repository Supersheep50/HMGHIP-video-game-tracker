@page "/login"
@layout AuthLayout
@inject NavigationManager Nav
@inject AuthStateService AuthState
@inject FirebaseService Firebase

<PageTitle>Welcome — HMGHIP</PageTitle>

<div class="welcome-page">

    <div class="welcome-hero">
        <svg class="welcome-icon" viewBox="0 0 24 24" fill="#a78bfa" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 9 18.5 9s1.5.67 1.5 1.5S19.33 12 18.5 12z"/>
        </svg>
        <h1 class="welcome-title">HMGHIP</h1>
        <p class="welcome-sub">How Many Games Have I Played</p>
        <p class="welcome-desc">Track every game you play, rate them, build your library.</p>
    </div>

    <div class="welcome-actions">
        <button class="welcome-google-btn" @onclick="SignInWithGoogle" disabled="@_loading">
            @if (_loading)
            {
                <span class="welcome-spinner"></span>
                <span>Signing in...</span>
            }
            else
            {
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="welcome-google-icon">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span>Continue with Google</span>
            }
        </button>

        <div class="welcome-divider"><span>or</span></div>

        <button class="welcome-guest-btn" @onclick="ContinueAsGuest">
            Continue as Guest
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
        </button>

        <p class="welcome-guest-note">Guest progress is not saved between sessions</p>
    </div>

</div>

@code {
    private bool _loading = false;

    private async Task SignInWithGoogle()
    {
        _loading = true;
        var user = await Firebase.SignInWithGoogleAsync();
        if (user != null)
        {
            AuthState.SignInWithUser(user);
            var profile = await Firebase.GetProfileAsync(user.Uid);
            Nav.NavigateTo(profile?.IsComplete == true ? "" : "setup", replace: true);
        }
        _loading = false;
    }

    private void ContinueAsGuest()
    {
        AuthState.SignInAsGuest();
        Nav.NavigateTo("", replace: true);
    }
}
