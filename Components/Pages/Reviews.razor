@page "/reviews"
@implements IDisposable
@inject RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState
@inject GameStateService GameState

<PageTitle>Reviews — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">Reviews</div>
            <p class="hero-title">Review Feed</p>
            <p class="hero-subtitle">Honest scores from you and your friends — no filler</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card anim-fade-up anim-delay-2">
                <span class="stat-number">@_myReviews.Count</span>
                <span class="stat-label">Yours</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-3">
                <span class="stat-number">@(_myReviews.Any() ? _myReviews.Average(r => r.Score).ToString("F1") : "—")</span>
                <span class="stat-label">Your Avg</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <div class="status-filter-row">
        <button class="status-filter-chip @(_filter == "all" ? "chip-active" : "")" @onclick='() => _filter = "all"'>
            All <span class="chip-count">@_allReviews.Count</span>
        </button>
        <button class="status-filter-chip @(_filter == "mine" ? "chip-active" : "")" @onclick='() => _filter = "mine"'>
            Yours <span class="chip-count">@_myReviews.Count</span>
        </button>
        <button class="status-filter-chip @(_filter == "friends" ? "chip-active" : "")" @onclick='() => _filter = "friends"'>
            Friends <span class="chip-count">@_allReviews.Count(r => r.Friend != null)</span>
        </button>
    </div>

    @if (!Shown.Any())
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.RateReview" Style="font-size: 4rem; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Class="mt-3">No reviews yet</MudText>
            <MudText Typo="Typo.body2">Finish a game and rate it — your review lands here</MudText>
        </div>
    }
    else
    {
        <div class="review-feed">
            @foreach (var review in Shown)
            {
                <div class="review-card clickable-tile"
                     @onclick="@(() => GameState.RequestOpenGame(review.GameName, review.ArtUrl, review.Genre, review.Friend == null ? "review" : "actions"))">
                    <div class="review-header">
                        @if (review.Friend != null)
                        {
                            <span class="review-avatar" style="background: @review.Friend.AvatarColor">@review.Friend.Initials</span>
                        }
                        else
                        {
                            <span class="review-avatar review-avatar-self">YOU</span>
                        }
                        <div class="review-author-block">
                            <div class="review-author">@(review.Friend?.Name ?? "You")</div>
                            <div class="review-when">@RelativeTime(review.When)</div>
                        </div>
                        <div class="review-score-pill @GameVisuals.RatingClass(review.Score)">
                            @review.Score.ToString("F1")<span class="review-score-sub">/10</span>
                        </div>
                    </div>
                    <div class="review-body">
                        <div class="review-game">@review.GameName</div>
                        <div class="review-stars">@GameVisuals.Stars(review.Score)</div>
                        @if (!string.IsNullOrWhiteSpace(review.ReviewText))
                        {
                            <p class="review-text">@review.ReviewText</p>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <div class="stub-card" style="margin-top: 2rem;">
        <h2 class="stub-section-title">How Scores Work</h2>
        <ul class="stub-list">
            <li>9–10 — Essential. Drop everything and play it.</li>
            <li>7–8 — Great. Well worth your time.</li>
            <li>5–6 — Decent. Has its moments.</li>
            <li>Below 5 — Disappointing or broken.</li>
        </ul>
    </div>

</MudContainer>

@code {
    private class ReviewItem
    {
        public string GameName { get; set; } = "";
        public string? ArtUrl { get; set; }
        public string? Genre { get; set; }
        public FakeFriend? Friend { get; set; }
        public double Score { get; set; }
        public string ReviewText { get; set; } = "";
        public DateTime When { get; set; }
    }

    private string _filter = "all";
    private List<ReviewItem> _allReviews = new();
    private List<ReviewItem> _myReviews = new();

    private IEnumerable<ReviewItem> Shown => _filter switch
    {
        "mine"    => _allReviews.Where(r => r.Friend == null),
        "friends" => _allReviews.Where(r => r.Friend != null),
        _         => _allReviews,
    };

    protected override async Task OnInitializedAsync()
    {
        GameState.OnChanged += OnGamesChanged;
        await LoadAsync();

        // Friend reviews + art lookups
        var friendReviews = FakeFriends.Reviews();
        var friendItems = friendReviews.Select(r => new ReviewItem
        {
            GameName   = r.GameName,
            Genre      = r.Genre,
            Friend     = r.Friend,
            Score      = r.Score,
            ReviewText = r.ReviewText,
            When       = r.When,
        }).ToList();

        _allReviews = _myReviews.Concat(friendItems).OrderByDescending(r => r.When).ToList();
        StateHasChanged();

        await Task.WhenAll(friendItems.Select(async f => f.ArtUrl = await RawgService.GetGameArtAsync(f.GameName)));
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        if (AuthState.CurrentUser == null) return;
        var games = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);
        _myReviews = games
            .Where(g => g.Review > 0 && g.Name != null)
            .Select(g => new ReviewItem
            {
                GameName   = g.Name!,
                ArtUrl     = g.GameArtUrl,
                Genre      = g.Genre,
                Friend     = null,
                Score      = g.Review,
                ReviewText = g.ReviewText ?? "",
                When       = DateTime.Now,
            })
            .ToList();
    }

    private async void OnGamesChanged()
    {
        await LoadAsync();
        var friendItems = _allReviews.Where(r => r.Friend != null).ToList();
        _allReviews = _myReviews.Concat(friendItems).OrderByDescending(r => r.When).ToList();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => GameState.OnChanged -= OnGamesChanged;

    private static string RelativeTime(DateTime when)
    {
        var span = DateTime.Now - when;
        if (span.TotalDays >= 30) return $"{(int)(span.TotalDays / 30)}mo ago";
        if (span.TotalDays >= 1)  return $"{(int)span.TotalDays}d ago";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h ago";
        return "just now";
    }
}
