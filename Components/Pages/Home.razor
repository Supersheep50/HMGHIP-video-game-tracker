@page "/"
@implements IDisposable
@inject PlayedGames.Services.RawgService RawgService
@inject FirebaseService Firebase
@inject AuthStateService AuthState
@inject GameStateService GameState

<PageTitle>HMGHIP — Games Played @DateTime.Now.Year</PageTitle>

<div class="hero-header">
    <div class="hero-carousel" aria-hidden="true">
        <div class="carousel-track">
            @for (int copy = 0; copy < 4; copy++)
            {
                @foreach (var game in _heroBackgroundGames)
                {
                    <div class="carousel-tile" style="background: @GameVisuals.Gradient(game.Genre)">
                        @if (!string.IsNullOrEmpty(game.ArtUrl))
                        {
                            <img src="@game.ArtUrl" alt="" class="carousel-img" />
                        }
                    </div>
                }
            }
        </div>
        <div class="hero-overlay"></div>
    </div>

    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">@DateTime.Now.Year</div>
            <p class="hero-title">Games Played</p>
            <p class="hero-subtitle">A running diary of every game played this year</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card anim-fade-up anim-delay-2">
                <span class="stat-number">@_yearGames.Count</span>
                <span class="stat-label">Games</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-3">
                <span class="stat-number">@_yearGames.Sum(g => g.HoursPlayed).ToString("N0")</span>
                <span class="stat-label">Hours</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-4">
                <span class="stat-number">@(_yearGames.Any(g => g.Review > 0) ? _yearGames.Where(g => g.Review > 0).Average(g => g.Review).ToString("F1") : "—")</span>
                <span class="stat-label">Avg Score</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    @* ── Currently Playing ───────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Currently Playing</h2>
            @if (_currentlyPlaying.Any())
            {
                <span class="section-count">@_currentlyPlaying.Count</span>
            }
        </div>
        @if (!_currentlyPlaying.Any())
        {
            <div class="section-empty">
                <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Style="font-size: 2.5rem; opacity: 0.3;" />
                <span>No games marked as playing yet</span>
            </div>
        }
        else
        {
            <div class="swipe-row playing-row">
                @foreach (var game in _currentlyPlaying)
                {
                    <div class="playing-card" @onclick="() => GameState.RequestOpenGame(game.Name!, game.GameArtUrl, game.Genre)">
                        <div class="playing-card-art" style="background: @GameVisuals.Gradient(game.Genre)">
                            @if (!string.IsNullOrEmpty(game.GameArtUrl))
                            {
                                <img src="@game.GameArtUrl" class="playing-card-img" alt="@game.Name" />
                            }
                            else
                            {
                                <MudIcon Icon="@GameVisuals.Icon(game.Genre)" Style="font-size: 3rem; opacity: 0.25; color: white;" />
                            }
                            <div class="playing-badge">
                                <span class="playing-pulse"></span> Playing
                            </div>
                        </div>
                        <div class="playing-card-body">
                            <p class="playing-card-name">@game.Name</p>
                            <div class="playing-card-meta">
                                @if (!string.IsNullOrEmpty(game.Genre))
                                {
                                    <span class="playing-card-genre">@game.Genre</span>
                                }
                                @if (game.HoursPlayed > 0)
                                {
                                    <span class="playing-card-hours">@game.HoursPlayed hrs</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* ── Games Played This Year ──────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Games Played This Year</h2>
            <span class="section-subtitle">Yours and your friends'</span>
        </div>
        <div class="swipe-row">
            @foreach (var item in _yearActivityFeed)
            {
                <div class="activity-tile clickable-tile" @onclick="() => GameState.RequestOpenGame(item.GameName, item.ArtUrl, item.Genre)" style="background: @GameVisuals.Gradient(item.Genre)">
                        @if (!string.IsNullOrEmpty(item.ArtUrl))
                        {
                            <img src="@item.ArtUrl" alt="" class="activity-tile-img" />
                        }
                        <div class="activity-tile-overlay">
                            <div class="activity-tile-game">@item.GameName</div>
                            <div class="activity-tile-meta">
                                @if (item.Friend != null)
                                {
                                    <span class="activity-avatar" style="background: @item.Friend.AvatarColor">@item.Friend.Initials</span>
                                    <span>@item.Friend.Name finished</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Style="color: #86efac;" />
                                    <span>You finished</span>
                                }
                            </div>
                        </div>
                </div>
            }
        </div>
    </section>

    @* ── Game Recommendations ────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Game Recommendations</h2>
            <span class="section-subtitle">Trending right now</span>
        </div>
        <div class="auto-carousel">
            <div class="auto-carousel-track auto-carousel-medium">
                @foreach (var rec in _recommendations.Concat(_recommendations))
                {
                    <div class="rec-tile clickable-tile" @onclick="() => GameState.RequestOpenGame(rec.Name, rec.ArtUrl, rec.Genre)" style="background: @GameVisuals.Gradient(rec.Genre)">
                        @if (!string.IsNullOrEmpty(rec.ArtUrl))
                        {
                            <img src="@rec.ArtUrl" alt="@rec.Name" class="rec-tile-img" />
                        }
                        else
                        {
                            <div class="rec-tile-icon">
                                <MudIcon Icon="@GameVisuals.Icon(rec.Genre)" Style="font-size: 3rem; opacity: 0.3; color: white;" />
                            </div>
                        }
                        <div class="rec-tile-overlay">
                            <div class="rec-tile-name">@rec.Name</div>
                            @if (!string.IsNullOrEmpty(rec.Genre))
                            {
                                <div class="rec-tile-genre">@rec.Genre</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ── Coming Soon ─────────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Coming Soon</h2>
            <span class="section-subtitle">Upcoming releases</span>
        </div>
        @if (!_upcoming.Any())
        {
            <div class="section-empty">
                <MudIcon Icon="@Icons.Material.Filled.Event" Style="font-size: 2.5rem; opacity: 0.3;" />
                <span>Loading upcoming releases…</span>
            </div>
        }
        else
        {
            <div class="swipe-row">
                @foreach (var u in _upcoming)
                {
                    <div class="activity-tile clickable-tile" @onclick="() => GameState.RequestOpenGame(u.Name, u.ArtUrl, u.Genre)" style="background: @GameVisuals.Gradient(u.Genre)">
                        @if (!string.IsNullOrEmpty(u.ArtUrl))
                        {
                            <img src="@u.ArtUrl" alt="" class="activity-tile-img" />
                        }
                        <div class="activity-tile-overlay">
                            <div class="activity-tile-game">@u.Name</div>
                            <div class="activity-tile-meta">
                                <span class="release-pill">
                                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Style="font-size: 0.9rem;" />
                                    @FormatRelease(u.Released)
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* ── Reviews ─────────────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Recent Reviews</h2>
            <span class="section-subtitle">From you and your friends</span>
        </div>
        <div class="reviews-row">
            @foreach (var review in _allReviews)
            {
                <div class="review-card clickable-tile" @onclick="() => OpenReview(review)">
                    <div class="review-header">
                        @if (review.Friend != null)
                        {
                            <span class="review-avatar" style="background: @review.Friend.AvatarColor">@review.Friend.Initials</span>
                        }
                        else
                        {
                            <span class="review-avatar review-avatar-self">YOU</span>
                        }
                        <div class="review-author-block">
                            <div class="review-author">@(review.Friend?.Name ?? "You")</div>
                            <div class="review-when">@RelativeTime(review.When)</div>
                        </div>
                        <div class="review-score-pill @GameVisuals.RatingClass(review.Score)">
                            @review.Score.ToString("F1")<span class="review-score-sub">/10</span>
                        </div>
                    </div>
                    <div class="review-body">
                        <div class="review-game">@review.GameName</div>
                        <div class="review-stars">@GameVisuals.Stars(review.Score)</div>
                        <p class="review-text">@review.ReviewText</p>
                    </div>
                </div>
            }
        </div>
    </section>

</MudContainer>

@if (_openReview != null)
{
    <div class="review-modal-backdrop" @onclick="CloseReview">
        <div class="review-modal" @onclick:stopPropagation="true">
            <button class="review-modal-close" @onclick="CloseReview" aria-label="Close">
                <MudIcon Icon="@Icons.Material.Filled.Close" />
            </button>

            <div class="review-modal-header">
                @if (_openReview.Friend != null)
                {
                    <span class="review-avatar review-avatar-lg" style="background: @_openReview.Friend.AvatarColor">@_openReview.Friend.Initials</span>
                }
                else
                {
                    <span class="review-avatar review-avatar-lg review-avatar-self">YOU</span>
                }
                <div class="review-modal-author-block">
                    <div class="review-modal-author">@(_openReview.Friend?.Name ?? "You")</div>
                    <div class="review-modal-when">@RelativeTime(_openReview.When)</div>
                </div>
                <div class="review-score-pill review-score-pill-lg @GameVisuals.RatingClass(_openReview.Score)">
                    @_openReview.Score.ToString("F1")<span class="review-score-sub">/10</span>
                </div>
            </div>

            <div class="review-modal-game-row">
                @if (!string.IsNullOrEmpty(_openReview.ArtUrl))
                {
                    <img src="@_openReview.ArtUrl" alt="@_openReview.GameName" class="review-modal-art" />
                }
                else
                {
                    <div class="review-modal-art" style="background: @GameVisuals.Gradient(_openReview.Genre); display:flex; align-items:center; justify-content:center;">
                        <MudIcon Icon="@GameVisuals.Icon(_openReview.Genre)" Style="font-size: 2rem; opacity: 0.4; color: white;" />
                    </div>
                }
                <div>
                    <div class="review-modal-game">@_openReview.GameName</div>
                    @if (!string.IsNullOrEmpty(_openReview.Genre))
                    {
                        <div class="review-modal-genre">@_openReview.Genre</div>
                    }
                    <div class="review-stars">@GameVisuals.Stars(_openReview.Score)</div>
                </div>
            </div>

            <p class="review-modal-text">@_openReview.ReviewText</p>

            <div class="review-modal-actions">
                <button class="review-upvote @(_reviewUpvoted ? "review-upvote-on" : "")" @onclick="ToggleUpvote">
                    <MudIcon Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" />
                    <span>@_reviewUpvoteCount</span>
                </button>
            </div>

            <div class="review-modal-comment">
                <textarea class="review-comment-input" placeholder="Add a comment…" @bind="_reviewComment" rows="3"></textarea>
                <div class="review-comment-actions">
                    <button class="review-comment-post" disabled="@string.IsNullOrWhiteSpace(_reviewComment)" @onclick="PostComment">Post</button>
                </div>

                @if (_reviewComments.Any())
                {
                    <div class="review-comment-list">
                        @foreach (var c in _reviewComments)
                        {
                            <div class="review-comment-item">
                                <span class="review-avatar review-avatar-self">YOU</span>
                                <div>
                                    <div class="review-comment-when">just now</div>
                                    <div class="review-comment-body">@c</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    // User's saved games (from Firebase)
    private List<Games> _allUserGames = new();
    private List<Games> _yearGames = new();
    private List<Games> _currentlyPlaying = new();
    private readonly HashSet<string> _playing = new();
    private readonly HashSet<string> _finished = new();

    // Hero background — lightweight tile data
    private List<TileData> _heroBackgroundGames = new();

    // Recommendations carousel
    private List<RawgSearchResult> _recommendations = new();

    // Coming Soon — upcoming RAWG releases
    private List<RawgUpcomingGame> _upcoming = new();

    // Combined "this year" feed (user finishes + friend finishes)
    private List<ActivityItem> _yearActivityFeed = new();

    // Combined reviews (user + friends)
    private List<ReviewItem> _allReviews = new();

    private record TileData(string? ArtUrl, string? Genre);

    private class ActivityItem
    {
        public string GameName { get; set; } = "";
        public string? ArtUrl { get; set; }
        public string? Genre { get; set; }
        public FakeFriend? Friend { get; set; }
        public DateTime When { get; set; }
    }

    private class ReviewItem
    {
        public string GameName { get; set; } = "";
        public string? ArtUrl { get; set; }
        public string? Genre { get; set; }
        public FakeFriend? Friend { get; set; }
        public double Score { get; set; }
        public string ReviewText { get; set; } = "";
        public DateTime When { get; set; }
    }

    // Cached friend data (loaded once, reused on every refresh)
    private List<FriendActivity> _friendFinishes = new();
    private List<FriendReview>   _friendReviews  = new();

    protected override async Task OnInitializedAsync()
    {
        GameState.OnChanged += OnGamesChanged;
        AuthState.OnChange  += OnAuthChanged;

        // Kick off RAWG popular + upcoming games in parallel
        var popularTask  = RawgService.GetPopularGamesAsync(20);
        var upcomingTask = RawgService.GetUpcomingGamesAsync(15);

        await LoadUserDataAsync();

        // Wait for popular games and use them for hero + recommendations
        var popular = await popularTask;
        _recommendations     = popular;
        _heroBackgroundGames = popular.Select(p => new TileData(p.ArtUrl, p.Genre)).ToList();

        _upcoming = await upcomingTask;

        // Load friend data + art (one-time)
        _friendFinishes = FakeFriends.RecentlyFinished();
        _friendReviews  = FakeFriends.Reviews();
        var friendArtTasks = _friendFinishes
            .Select(async f => f.GameArtUrl = await RawgService.GetGameArtAsync(f.GameName))
            .Concat(_friendReviews.Select(async r => r.GameArtUrl = await RawgService.GetGameArtAsync(r.GameName)));
        await Task.WhenAll(friendArtTasks);

        RebuildFeeds();
        StateHasChanged();
    }

    private async Task LoadUserDataAsync()
    {
        if (AuthState.CurrentUser == null) return;

        _allUserGames = await Firebase.GetGamesAsync(AuthState.CurrentUser.Uid);

        _playing.Clear();
        _finished.Clear();
        var statuses = await Firebase.GetGameStatusesAsync(AuthState.CurrentUser.Uid);
        foreach (var (name, status) in statuses)
        {
            if (status == "playing")       _playing.Add(name);
            else if (status == "finished") _finished.Add(name);
        }

        // "Played this year" = finished status (legacy entries fall back to logged hours)
        _yearGames = _allUserGames
            .Where(g => g.Year == DateTime.Now.Year &&
                        (g.Name != null && _finished.Contains(g.Name) || g.HoursPlayed > 0))
            .ToList();

        _currentlyPlaying = _allUserGames
            .Where(g => g.Name != null && _playing.Contains(g.Name))
            .ToList();

        // Backfill missing art best-effort
        var artTasks = _allUserGames.Where(g => string.IsNullOrEmpty(g.GameArtUrl)).Select(async game =>
        {
            game.GameArtUrl = await RawgService.GetGameArtAsync(game.Name);
        });
        await Task.WhenAll(artTasks);
    }

    private void RebuildFeeds()
    {
        var userYearFinishes = _yearGames
            .Select(g => new ActivityItem
            {
                GameName = g.Name ?? "",
                ArtUrl   = g.GameArtUrl,
                Genre    = g.Genre,
                Friend   = null,
                When     = DateTime.Now,
            });

        var friendYearFinishes = _friendFinishes.Select(f => new ActivityItem
        {
            GameName = f.GameName,
            ArtUrl   = f.GameArtUrl,
            Genre    = f.Genre,
            Friend   = f.Friend,
            When     = f.When,
        });

        _yearActivityFeed = userYearFinishes.Concat(friendYearFinishes)
            .OrderByDescending(a => a.When)
            .ToList();

        var userReviews = _allUserGames
            .Where(g => !string.IsNullOrWhiteSpace(g.ReviewText) && g.Review > 0)
            .Select(g => new ReviewItem
            {
                GameName   = g.Name ?? "",
                ArtUrl     = g.GameArtUrl,
                Genre      = g.Genre,
                Friend     = null,
                Score      = g.Review,
                ReviewText = g.ReviewText ?? "",
                When       = DateTime.Now,
            });

        var friendReviewItems = _friendReviews.Select(r => new ReviewItem
        {
            GameName   = r.GameName,
            ArtUrl     = r.GameArtUrl,
            Genre      = r.Genre,
            Friend     = r.Friend,
            Score      = r.Score,
            ReviewText = r.ReviewText,
            When       = r.When,
        });

        _allReviews = userReviews.Concat(friendReviewItems)
            .OrderByDescending(r => r.When)
            .ToList();
    }

    private async void OnGamesChanged()
    {
        await LoadUserDataAsync();
        RebuildFeeds();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthChanged()
    {
        await LoadUserDataAsync();
        RebuildFeeds();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GameState.OnChanged -= OnGamesChanged;
        AuthState.OnChange  -= OnAuthChanged;
    }

    // ── Expanded review modal state (UI only, not persisted) ─────────────
    private ReviewItem? _openReview;
    private bool       _reviewUpvoted;
    private int        _reviewUpvoteCount;
    private string     _reviewComment = "";
    private List<string> _reviewComments = new();

    private void OpenReview(ReviewItem r)
    {
        _openReview        = r;
        _reviewUpvoted     = false;
        _reviewUpvoteCount = new Random(r.GameName.GetHashCode()).Next(3, 47);
        _reviewComment     = "";
        _reviewComments    = new();
    }

    private void CloseReview() => _openReview = null;

    private void ToggleUpvote()
    {
        _reviewUpvoted = !_reviewUpvoted;
        _reviewUpvoteCount += _reviewUpvoted ? 1 : -1;
    }

    private void PostComment()
    {
        if (string.IsNullOrWhiteSpace(_reviewComment)) return;
        _reviewComments.Insert(0, _reviewComment.Trim());
        _reviewComment = "";
    }

    private static string FormatRelease(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "TBA";
        var days = (dt.Date - DateTime.UtcNow.Date).TotalDays;
        if (days <= 0)  return "Out now";
        if (days <= 7)  return $"In {(int)days}d";
        if (dt.Year == DateTime.UtcNow.Year) return dt.ToString("MMM d");
        return dt.ToString("MMM yyyy");
    }

    private static string RelativeTime(DateTime when)
    {
        var span = DateTime.Now - when;
        if (span.TotalDays >= 30) return $"{(int)(span.TotalDays / 30)}mo ago";
        if (span.TotalDays >= 1)  return $"{(int)span.TotalDays}d ago";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h ago";
        return "just now";
    }

}
