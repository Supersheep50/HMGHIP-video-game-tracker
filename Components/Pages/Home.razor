@page "/"
@inject PlayedGames.Services.RawgService RawgService

<PageTitle>HMGHIP — Games Played 2026</PageTitle>

<div class="hero-header">
    <!-- Scrolling carousel background — quad-duplicated so 5 tiles fills the track -->
    <div class="hero-carousel" aria-hidden="true">
        <div class="carousel-track">
            @for (int copy = 0; copy < 4; copy++)
            {
                @foreach (var game in GamesList)
                {
                    <div class="carousel-tile" style="background: @GetGenreGradient(game.Genre)">
                        @if (!string.IsNullOrEmpty(game.GameArtUrl))
                        {
                            <img src="@game.GameArtUrl" alt="" class="carousel-img" />
                        }
                    </div>
                }
            }
        </div>
        <div class="hero-overlay"></div>
    </div>

    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">2026</div>
            <p class="hero-title">Games Played</p>
            <p class="hero-subtitle">A running diary of every game played this year</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card anim-fade-up anim-delay-2">
                <span class="stat-number">@GamesList.Count</span>
                <span class="stat-label">Games</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-3">
                <span class="stat-number">@GamesList.Sum(g => g.HoursPlayed).ToString("N0")</span>
                <span class="stat-label">Hours</span>
            </div>
            <div class="stat-card anim-fade-up anim-delay-4">
                <span class="stat-number">@(GamesList.Any() ? GamesList.Average(g => g.Review).ToString("F1") : "—")</span>
                <span class="stat-label">Avg Score</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <MudGrid Spacing="3">
        @{ int cardIdx = 0; }
        @foreach (var game in GamesList)
        {
            var delay = $"animation-delay:{cardIdx * 0.1}s";
            cardIdx++;
            <MudItem xs="12" sm="6" md="4" lg="3">
                <div class="card-reveal" style="@delay">
                <MudCard Class="game-card" Elevation="0">
                    <div class="card-art @(game.GameArtUrl == null ? "card-art-loading" : "")"
                         style="background: @GetGenreGradient(game.Genre)">
                        @if (!string.IsNullOrEmpty(game.GameArtUrl))
                        {
                            <img src="@game.GameArtUrl" class="card-art-img" alt="@game.Name" />
                        }
                        else
                        {
                            <div class="card-art-icon">
                                <MudIcon Icon="@GetGenreIcon(game.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                            </div>
                        }
                    </div>
                    <MudCardContent Class="card-body">
                        <div class="card-title-row">
                            <p class="game-name">@game.Name</p>
                            <span class="card-score @GetRatingClass(game.Review)">@game.Review.ToString("F1")<span class="card-score-sub">/10</span></span>
                        </div>
                        <div class="card-stars-wrap">@RenderStars(game.Review)</div>
                        <div class="card-meta-row">
                            <p class="game-developer">@game.Developer</p>
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="tag-chip">@game.System</MudChip>
                        </div>
                        <div class="card-info-row">
                            <div class="card-hltb">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
                                <span>~@game.HowLongToBeat hrs to beat</span>
                            </div>
                            <div class="card-played">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="hours-icon" />
                                <span class="hours-text">@game.HoursPlayed hrs played</span>
                            </div>
                        </div>
                        <div class="card-tags">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@game.Genre</MudChip>
                        </div>
                    </MudCardContent>
                    <div class="card-actions">
                        <button class="card-action-btn card-action-playing @(_playing.Contains(game.Name!) ? "action-active" : "")" @onclick="() => TogglePlaying(game)">
                            @if (_playing.Contains(game.Name!)) {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            } else {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                            }
                            Playing
                        </button>
                        <button class="card-action-btn card-action-finished @(_finished.Contains(game.Name!) ? "action-active" : "")" @onclick="() => ToggleFinished(game)">
                            @if (_finished.Contains(game.Name!)) {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            } else {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                            }
                            Finished
                        </button>
                    </div>
                </MudCard>
                </div>
            </MudItem>
        }
    </MudGrid>

</MudContainer>

@code {
    private readonly List<Games> GamesList = new()
    {
        new Games { Name = "Baldur's Gate 3",                           Genre = "RPG",              System = "PC",              Developer = "Larian Studios",      HoursPlayed = 120, Review = 10.0, HowLongToBeat = 100 },
        new Games { Name = "Elden Ring",                                Genre = "Action RPG",       System = "PC",              Developer = "FromSoftware",        HoursPlayed = 95,  Review = 9.5,  HowLongToBeat = 60  },
        new Games { Name = "God of War: Ragnarök",                      Genre = "Action-Adventure", System = "PlayStation 5",   Developer = "Santa Monica Studio", HoursPlayed = 40,  Review = 9.5,  HowLongToBeat = 26  },
        new Games { Name = "Alan Wake 2",                               Genre = "Action-Adventure", System = "PC",              Developer = "Remedy Entertainment",HoursPlayed = 20,  Review = 8.5,  HowLongToBeat = 15  },
        new Games { Name = "The Legend of Zelda: Tears of the Kingdom", Genre = "Action-Adventure", System = "Nintendo Switch", Developer = "Nintendo",            HoursPlayed = 120, Review = 10.0, HowLongToBeat = 50  },
    };

    protected override async Task OnInitializedAsync()
    {
        var tasks = GamesList.Select(async game =>
        {
            game.GameArtUrl = await RawgService.GetGameArtAsync(game.Name);
            await InvokeAsync(StateHasChanged);
        });
        await Task.WhenAll(tasks);
    }

    private readonly HashSet<string> _playing  = new();
    private readonly HashSet<string> _finished = new();

    private void TogglePlaying(Games game)
    {
        if (!_playing.Add(game.Name!)) _playing.Remove(game.Name!);
        else _finished.Remove(game.Name!);
    }

    private void ToggleFinished(Games game)
    {
        if (!_finished.Add(game.Name!)) _finished.Remove(game.Name!);
        else _playing.Remove(game.Name!);
    }

    private static MarkupString RenderStars(double score)
    {
        double stars = score / 2.0;
        int full  = (int)Math.Floor(stars);
        bool half = (stars - full) >= 0.5;
        int empty = 5 - full - (half ? 1 : 0);
        const string F = "<svg class='star star-full'  viewBox='0 0 24 24'><path d='M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z'/></svg>";
        const string H = "<svg class='star star-half'  viewBox='0 0 24 24'><path d='M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4V6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z'/></svg>";
        const string E = "<svg class='star star-empty' viewBox='0 0 24 24'><path d='M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z'/></svg>";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < full;  i++) sb.Append(F);
        if (half) sb.Append(H);
        for (int i = 0; i < empty; i++) sb.Append(E);
        return new MarkupString(sb.ToString());
    }

    private string GetRatingClass(double r) => r switch
    {
        >= 9 => "rating-excellent",
        >= 7 => "rating-good",
        >= 5 => "rating-average",
        _    => "rating-poor"
    };

    private string GetGenreGradient(string? genre) => genre switch
    {
        "Action RPG"       => "linear-gradient(145deg, #1e0a3c 0%, #6b21a8 100%)",
        "RPG"              => "linear-gradient(145deg, #0d1b4b 0%, #1d4ed8 100%)",
        "Action-Adventure" => "linear-gradient(145deg, #1c0505 0%, #991b1b 100%)",
        "JRPG"             => "linear-gradient(145deg, #3b0000 0%, #dc2626 100%)",
        "Roguelike"        => "linear-gradient(145deg, #0a0a1a 0%, #4338ca 100%)",
        "Metroidvania"     => "linear-gradient(145deg, #000d10 0%, #0e7490 100%)",
        "Simulation"       => "linear-gradient(145deg, #0a1a0a 0%, #15803d 100%)",
        "MMORPG"           => "linear-gradient(145deg, #1a1000 0%, #b45309 100%)",
        "Action"           => "linear-gradient(145deg, #1a0a00 0%, #c2410c 100%)",
        "Platformer"       => "linear-gradient(145deg, #0a1a2a 0%, #0369a1 100%)",
        "Racing"           => "linear-gradient(145deg, #1a0a00 0%, #d97706 100%)",
        _                  => "linear-gradient(145deg, #1a1a2e 0%, #374151 100%)",
    };

    private string GetGenreIcon(string? genre) => genre switch
    {
        "Action RPG"       => Icons.Material.Filled.AutoFixHigh,
        "RPG"              => Icons.Material.Filled.AutoAwesome,
        "Action-Adventure" => Icons.Material.Filled.Explore,
        "JRPG"             => Icons.Material.Filled.Stars,
        "Roguelike"        => Icons.Material.Filled.Loop,
        "Metroidvania"     => Icons.Material.Filled.Terrain,
        "Simulation"       => Icons.Material.Filled.Yard,
        "MMORPG"           => Icons.Material.Filled.Groups,
        "Action"           => Icons.Material.Filled.FlashOn,
        "Platformer"       => Icons.Material.Filled.DirectionsRun,
        "Racing"           => Icons.Material.Filled.Speed,
        _                  => Icons.Material.Filled.SportsEsports,
    };
}
