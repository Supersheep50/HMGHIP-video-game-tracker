@page "/contact"

<PageTitle>Contact — HMGHIP</PageTitle>

<div class="stub-page">
    <div class="stub-hero">
        <div class="stub-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <h1 class="stub-title">Contact</h1>
        <p class="stub-lead">Got a suggestion, spotted a bug, or just want to talk games? Reach out.</p>
    </div>

    <div class="stub-body">
        <div class="stub-card">
            <h2 class="stub-section-title">Get In Touch</h2>
            <p>Found a bug, want a feature, or disagree violently with a score? Drop a message — every email gets read, even the ones defending Cyberpunk's launch.</p>

            <div class="stub-form">
                <div class="stub-field">
                    <label class="stub-label">Name</label>
                    <input class="stub-input" type="text" placeholder="Your name" @bind="_name" @bind:event="oninput" />
                </div>
                <div class="stub-field">
                    <label class="stub-label">Message</label>
                    <textarea class="stub-input stub-textarea" placeholder="What's on your mind?" @bind="_message" @bind:event="oninput"></textarea>
                </div>
                <a class="setup-next-btn" style="text-decoration:none; text-align:center;"
                   href="@MailtoLink">
                    Send via Email
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _name = "";
    private string _message = "";

    private string MailtoLink =>
        "mailto:jonathan.morrisseyto@gmail.com"
        + "?subject=" + Uri.EscapeDataString($"HMGHIP feedback from {(_name.Length > 0 ? _name : "a player")}")
        + "&body=" + Uri.EscapeDataString(_message);
}
