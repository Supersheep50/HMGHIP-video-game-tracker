@page "/game-news"
@inject RawgService RawgService
@inject NewsService News
@inject GameStateService GameState

<PageTitle>Game News — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">What's New</div>
            <p class="hero-title">Game News</p>
            <p class="hero-subtitle">Fresh releases and what's coming next</p>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    @* ── Headlines ───────────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Headlines</h2>
            <span class="section-subtitle">IGN · GameSpot · Eurogamer</span>
        </div>
        @if (_loadingNews)
        {
            <div class="section-empty">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                <span>Loading headlines…</span>
            </div>
        }
        else if (!_headlines.Any())
        {
            <div class="section-empty">
                <MudIcon Icon="@Icons.Material.Filled.Newspaper" Style="font-size: 2.5rem; opacity: 0.3;" />
                <span>Couldn't load headlines right now</span>
            </div>
        }
        else
        {
            var featured = _headlines[0];
            <a class="news-featured" href="@featured.Link" target="_blank" rel="noopener">
                @if (!string.IsNullOrEmpty(featured.ImageUrl))
                {
                    <img src="@featured.ImageUrl" class="news-featured-img" alt="" loading="lazy" />
                }
                <div class="news-featured-overlay">
                    <span class="news-source-pill">@featured.Source</span>
                    <h3 class="news-featured-title">@featured.Title</h3>
                    <span class="news-time">@RelativeTime(featured.Published)</span>
                </div>
            </a>

            <div class="news-list">
                @foreach (var n in _headlines.Skip(1).Take(_newsShown))
                {
                    <a class="news-row" href="@n.Link" target="_blank" rel="noopener">
                        @if (!string.IsNullOrEmpty(n.ImageUrl))
                        {
                            <img src="@n.ImageUrl" class="news-row-img" alt="" loading="lazy" />
                        }
                        else
                        {
                            <div class="news-row-img news-row-noimg">
                                <MudIcon Icon="@Icons.Material.Filled.Newspaper" Style="opacity: 0.3;" />
                            </div>
                        }
                        <div class="news-row-text">
                            <p class="news-row-title">@n.Title</p>
                            <p class="news-row-meta">@n.Source · @RelativeTime(n.Published)</p>
                        </div>
                    </a>
                }
            </div>
            @if (_headlines.Count - 1 > _newsShown)
            {
                <div class="load-more-wrap">
                    <button class="load-more-btn" @onclick="() => _newsShown += 10">More Headlines</button>
                </div>
            }
        }
    </section>

    @* ── Just Released ───────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Just Released</h2>
            <span class="section-subtitle">The last 60 days</span>
        </div>
        @if (_loadingRecent)
        {
            <div class="section-empty">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                <span>Loading new releases…</span>
            </div>
        }
        else if (!_recent.Any())
        {
            <div class="section-empty">
                <MudIcon Icon="@Icons.Material.Filled.NewReleases" Style="font-size: 2.5rem; opacity: 0.3;" />
                <span>Couldn't load releases right now</span>
            </div>
        }
        else
        {
            <div class="swipe-row">
                @foreach (var g in _recent)
                {
                    <div class="activity-tile clickable-tile" @onclick="() => GameState.RequestOpenGame(g.Name, g.ArtUrl, g.Genre)" style="background: @GameVisuals.Gradient(g.Genre)">
                        @if (!string.IsNullOrEmpty(g.ArtUrl))
                        {
                            <img src="@g.ArtUrl" alt="" class="activity-tile-img" loading="lazy" />
                        }
                        <div class="activity-tile-overlay">
                            <div class="activity-tile-game">@g.Name</div>
                            <div class="activity-tile-meta">
                                <span class="release-pill">
                                    <MudIcon Icon="@Icons.Material.Filled.NewReleases" Size="Size.Small" Style="font-size: 0.9rem;" />
                                    @FormatDate(g.Released)
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* ── Coming Soon ─────────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Coming Soon</h2>
            <span class="section-subtitle">Upcoming releases</span>
        </div>
        @if (_loadingUpcoming)
        {
            <div class="section-empty">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                <span>Loading upcoming releases…</span>
            </div>
        }
        else if (!_upcoming.Any())
        {
            <div class="section-empty">
                <MudIcon Icon="@Icons.Material.Filled.Event" Style="font-size: 2.5rem; opacity: 0.3;" />
                <span>Couldn't load upcoming games right now</span>
            </div>
        }
        else
        {
            <div class="swipe-row">
                @foreach (var u in _upcoming)
                {
                    <div class="activity-tile clickable-tile" @onclick="() => GameState.RequestOpenGame(u.Name, u.ArtUrl, u.Genre)" style="background: @GameVisuals.Gradient(u.Genre)">
                        @if (!string.IsNullOrEmpty(u.ArtUrl))
                        {
                            <img src="@u.ArtUrl" alt="" class="activity-tile-img" loading="lazy" />
                        }
                        <div class="activity-tile-overlay">
                            <div class="activity-tile-game">@u.Name</div>
                            <div class="activity-tile-meta">
                                <span class="release-pill">
                                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Style="font-size: 0.9rem;" />
                                    @FormatCountdown(u.Released)
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    @* ── Trending ────────────────────────────────────────────────────── *@
    <section class="home-section">
        <div class="section-head">
            <h2 class="section-title">Trending</h2>
            <span class="section-subtitle">What everyone's playing</span>
        </div>
        @if (_trending.Any())
        {
            <MudGrid Spacing="3">
                @foreach (var t in _trending.Take(12))
                {
                    <MudItem xs="6" sm="4" md="3" lg="2">
                        <div class="discover-tile" @onclick="() => GameState.RequestOpenGame(t.Name, t.ArtUrl, t.Genre)">
                            <div class="discover-tile-art" style="background: @GameVisuals.Gradient(t.Genre)">
                                @if (!string.IsNullOrEmpty(t.ArtUrl))
                                {
                                    <img src="@t.ArtUrl" class="discover-tile-img" alt="@t.Name" loading="lazy" />
                                }
                                else
                                {
                                    <MudIcon Icon="@GameVisuals.Icon(t.Genre)" Style="font-size: 2.5rem; opacity: 0.25; color: white;" />
                                }
                            </div>
                            <div class="discover-tile-body">
                                <p class="discover-tile-name">@t.Name</p>
                                <p class="discover-tile-meta">@(t.Genre ?? "Game")</p>
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        }
    </section>

</MudContainer>

@code {
    private List<NewsItem> _headlines = new();
    private List<RawgSearchResult> _recent = new();
    private List<RawgUpcomingGame> _upcoming = new();
    private List<RawgSearchResult> _trending = new();
    private bool _loadingNews = true;
    private bool _loadingRecent = true;
    private bool _loadingUpcoming = true;
    private int _newsShown = 6;

    protected override async Task OnInitializedAsync()
    {
        var newsTask     = News.GetHeadlinesAsync();
        var recentTask   = RawgService.GetRecentReleasesAsync(15);
        var upcomingTask = RawgService.GetUpcomingGamesAsync(15);
        var trendingTask = RawgService.GetPopularGamesAsync(12);

        _headlines = await newsTask;
        _loadingNews = false;
        StateHasChanged();

        _recent = await recentTask;
        _loadingRecent = false;
        StateHasChanged();

        _upcoming = await upcomingTask;
        _loadingUpcoming = false;
        _trending = await trendingTask;
    }

    private static string RelativeTime(DateTime? when)
    {
        if (when == null) return "";
        var span = DateTime.UtcNow - when.Value;
        if (span.TotalDays >= 2)  return $"{(int)span.TotalDays}d ago";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h ago";
        if (span.TotalMinutes >= 1) return $"{(int)span.TotalMinutes}m ago";
        return "just now";
    }

    private static string FormatDate(string? iso) =>
        DateTime.TryParse(iso, out var dt) ? dt.ToString("MMM d") : "New";

    private static string FormatCountdown(string? iso)
    {
        if (string.IsNullOrEmpty(iso) || !DateTime.TryParse(iso, out var dt)) return "TBA";
        var days = (dt.Date - DateTime.UtcNow.Date).TotalDays;
        if (days <= 0)  return "Out now";
        if (days <= 7)  return $"In {(int)days}d";
        if (dt.Year == DateTime.UtcNow.Year) return dt.ToString("MMM d");
        return dt.ToString("MMM yyyy");
    }
}
