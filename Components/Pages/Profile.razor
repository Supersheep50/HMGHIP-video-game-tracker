@page "/profile"
@implements IDisposable
@inject AuthStateService AuthState
@inject FirebaseService Firebase
@inject XpService Xp
@inject NavigationManager Nav

<PageTitle>My Profile — HMGHIP</PageTitle>

<div class="profile-page">

    @if (AuthState.CurrentUser != null)
    {
        <div class="profile-hero anim-fade-up">
            <div class="profile-avatar-wrap">
                @if (AuthState.CurrentUser.PhotoUrl != null)
                {
                    <img src="@AuthState.CurrentUser.PhotoUrl" class="profile-hero-avatar" alt="avatar" />
                }
                else
                {
                    <div class="profile-hero-avatar profile-hero-avatar-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                }
            </div>
            <h1 class="profile-display-name">@AuthState.CurrentUser.DisplayName</h1>
            <p class="profile-email">@AuthState.CurrentUser.Email</p>
        </div>
    }
    else
    {
        <div class="profile-hero anim-fade-up">
            <div class="profile-hero-avatar profile-hero-avatar-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </div>
            <h1 class="profile-display-name">Guest</h1>
            <p class="profile-email">Not signed in</p>
            <a href="login" class="profile-signin-btn">Sign in with Google</a>
        </div>
    }

    @if (AuthState.IsAuthenticated && AuthState.CurrentUser != null)
    {
        var lvl  = Xp.CurrentLevel;
        var next = Xp.NextLevel;
        var pct  = Math.Round(Xp.Progress * 100);

        <div class="xp-card anim-fade-up">
            <div class="xp-card-badge-wrap">
                <div class="xp-card-badge-ring" style="--xp-ring: @pct%"></div>
                <div class="xp-card-badge">
                    <span class="xp-card-badge-icon">@lvl.Badge</span>
                </div>
                <div class="xp-card-badge-num">@lvl.Number</div>
            </div>

            <div class="xp-card-level-label">Level @lvl.Number</div>
            <h2 class="xp-card-level-name">@lvl.Name</h2>
            <div class="xp-card-level-num">@Xp.Xp XP total</div>

            <div class="xp-card-track">
                <div class="xp-card-fill" style="width: @pct%"></div>
            </div>

            @if (next != null)
            {
                <div class="xp-card-numbers">
                    <span><strong>@Xp.Xp</strong></span>
                    <span class="xp-card-numbers-mid">@(next.XpRequired - Xp.Xp) XP to next</span>
                    <span><strong>@next.XpRequired</strong></span>
                </div>
                <div class="xp-card-next">
                    <span>Next:</span>
                    <span class="xp-card-next-badge">@next.Badge</span>
                    <span><strong>Lvl @next.Number</strong> — @next.Name</span>
                </div>
            }
            else
            {
                <div class="xp-card-numbers">
                    <span><strong>@Xp.Xp</strong> XP</span>
                </div>
                <div class="xp-card-max">🏆 Max level reached</div>
            }

            <div class="xp-journey">
                @foreach (var step in XpLevels.All)
                {
                    var state = step.Number < lvl.Number ? "done"
                              : step.Number == lvl.Number ? "current" : "locked";
                    <div class="xp-journey-step xp-journey-@state" title="Lvl @step.Number — @step.Name">
                        <span class="xp-journey-badge">@step.Badge</span>
                        <span class="xp-journey-num">@step.Number</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="profile-actions anim-fade-up">
        @if (AuthState.IsAuthenticated && !AuthState.IsGuest)
        {
            <a href="logout" class="profile-signout-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                Sign Out
            </a>
        }
    </div>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Xp.OnChanged += HandleXpChanged;
        await Xp.EnsureLoadedAsync();
    }

    private void HandleXpChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Xp.OnChanged -= HandleXpChanged;
}
