    private IEnumerable<CatalogGame> Filtered =>
        Catalog.Where(g =>
            string.IsNullOrWhiteSpace(_search) ||
            g.Title.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            g.Genre.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            g.Platform.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            g.Developer.Contains(_search, StringComparison.OrdinalIgnoreCase)
        ).OrderBy(g => g.Title);

    private void Add(CatalogGame game, string list)
    {
        var (icon, color, label) = list switch
        {
            "Library" => (Icons.Material.Filled.LibraryAddCheck, Severity.Success,  $"{game.Title} added to Library"),
            "Playing" => (Icons.Material.Filled.PlayCircle,       Severity.Info,     $"{game.Title} added to Currently Playing"),
            _         => (Icons.Material.Filled.StarRate,          Severity.Normal,   $"{game.Title} added to Reviews"),
        };
        Snackbar.Add(label, color, config => { config.Icon = icon; });
    }

    private static string GenreGradient(string genre) => genre switch
    {
