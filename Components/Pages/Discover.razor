@page "/discover"
@inject RawgService RawgService
@inject GameStateService GameState

<PageTitle>Discover — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section anim-fade-up">
            <div class="year-badge">Discover</div>
            <p class="hero-title">Find Your Next Game</p>
            <p class="hero-subtitle">Browse the catalog, tap a game, track it</p>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <MudTextField @bind-Value="_search"
                  Placeholder="Search the entire games catalog..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Immediate="true"
                  DebounceInterval="450"
                  OnDebounceIntervalElapsed="RunSearch"
                  Class="library-search"
                  FullWidth="true" />

    @if (string.IsNullOrWhiteSpace(_search))
    {
        <div class="status-filter-row">
            @foreach (var g in GenreFilters)
            {
                <button class="status-filter-chip @(_genre == g.Slug ? "chip-active" : "")"
                        @onclick="() => SelectGenre(g.Slug)">
                    @g.Label
                </button>
            }
        </div>
    }

    @if (_loading)
    {
        <div class="search-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
            <span>Loading games...</span>
        </div>
    }
    else if (!Shown.Any())
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 4rem; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Class="mt-3">No games found</MudText>
            <MudText Typo="Typo.body2">Try a different search or genre</MudText>
        </div>
    }
    else
    {
        <MudGrid Spacing="3">
            @{ int cardIdx = 0; }
            @foreach (var game in Shown)
            {
                var delay = $"animation-delay:{Math.Min(cardIdx, 12) * 0.05}s";
                cardIdx++;
                <MudItem xs="6" sm="4" md="3" lg="2">
                    <div class="discover-tile card-reveal" style="@delay"
                         @onclick="() => GameState.RequestOpenGame(game.Name, game.ArtUrl, game.Genre)">
                        <div class="discover-tile-art" style="background: @GameVisuals.Gradient(game.Genre)">
                            @if (!string.IsNullOrEmpty(game.ArtUrl))
                            {
                                <img src="@game.ArtUrl" class="discover-tile-img" alt="@game.Name" loading="lazy" />
                            }
                            else
                            {
                                <MudIcon Icon="@GameVisuals.Icon(game.Genre)" Style="font-size: 2.5rem; opacity: 0.25; color: white;" />
                            }
                            @if (game.Metacritic is int mc)
                            {
                                <span class="discover-tile-mc @GameVisuals.RatingClass(mc / 10.0)">@mc</span>
                            }
                        </div>
                        <div class="discover-tile-body">
                            <p class="discover-tile-name">@game.Name</p>
                            <p class="discover-tile-meta">
                                @(game.Genre ?? "Game")@(ReleaseYear(game.Released) is string y ? $" · {y}" : "")
                            </p>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>

        @if (string.IsNullOrWhiteSpace(_search))
        {
            <div class="load-more-wrap">
                <button class="load-more-btn" @onclick="LoadMore" disabled="@_loadingMore">
                    @(_loadingMore ? "Loading..." : "Load More")
                </button>
            </div>
        }
    }

</MudContainer>

@code {
    private record GenreFilter(string Label, string? Slug);

    private static readonly GenreFilter[] GenreFilters =
    {
        new("All", null),
        new("Action", "action"),
        new("Adventure", "adventure"),
        new("RPG", "role-playing-games-rpg"),
        new("Shooter", "shooter"),
        new("Indie", "indie"),
        new("Strategy", "strategy"),
        new("Simulation", "simulation"),
        new("Platformer", "platformer"),
        new("Puzzle", "puzzle"),
        new("Racing", "racing"),
        new("Sports", "sports"),
    };

    private string _search = "";
    private string? _genre;
    private int _page = 1;
    private bool _loading;
    private bool _loadingMore;

    private List<RawgSearchResult> _browse = new();
    private List<RawgSearchResult> _searchResults = new();

    private IEnumerable<RawgSearchResult> Shown =>
        string.IsNullOrWhiteSpace(_search) ? _browse : _searchResults;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _browse = await RawgService.BrowseGamesAsync(null, 1);
        _loading = false;
    }

    private async Task SelectGenre(string? slug)
    {
        _genre = slug;
        _page = 1;
        _loading = true;
        _browse = await RawgService.BrowseGamesAsync(_genre, 1);
        _loading = false;
    }

    private async Task LoadMore()
    {
        _loadingMore = true;
        _page++;
        var more = await RawgService.BrowseGamesAsync(_genre, _page);
        // De-dupe: RAWG occasionally repeats entries across pages
        var seen = _browse.Select(b => b.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _browse = _browse.Concat(more.Where(m => seen.Add(m.Name))).ToList();
        _loadingMore = false;
    }

    private async Task RunSearch(string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            _searchResults = new();
            return;
        }
        _loading = true;
        StateHasChanged();
        _searchResults = await RawgService.SearchGamesAsync(query);
        _loading = false;
    }

    private static string? ReleaseYear(string? iso) =>
        DateTime.TryParse(iso, out var dt) ? dt.Year.ToString() : null;
}
