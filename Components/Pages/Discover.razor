@page "/discover"
@inject ISnackbar Snackbar

<PageTitle>Discover — HMGHIP</PageTitle>

<div class="hero-header library-hero">
    <div class="hero-inner">
        <div class="hero-title-section">
            <div class="year-badge">Discover</div>
            <p class="hero-title">Add Games</p>
            <p class="hero-subtitle">Search for a game and add it to your lists</p>
        </div>
        <div class="hero-stats">
            <div class="stat-card">
                <span class="stat-number">@Catalog.Count</span>
                <span class="stat-label">Games</span>
            </div>
        </div>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="library-container">

    <div class="filter-row">
        <MudTextField @bind-Value="_search"
                      Placeholder="Search by title, genre or platform..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="search-input"
                      Immediate="true" />
    </div>

    <MudText Typo="Typo.body2" Class="results-count">
        Showing @Filtered.Count() of @Catalog.Count games
    </MudText>

    <MudGrid Spacing="3">
        @foreach (var game in Filtered)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <div class="discover-card">
                    <!-- Art -->
                    <div class="card-art" style="background: @GenreGradient(game.Genre)">
                        <div class="card-art-icon">
                            <MudIcon Icon="@GenreIcon(game.Genre)" Style="font-size: 3.5rem; opacity: 0.25; color: white;" />
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="discover-body">
                        <p class="game-name">@game.Title</p>
                        <p class="game-developer">@game.Developer · @game.ReleaseYear</p>
                        <div class="card-tags">
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="tag-chip">@game.Platform</MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="tag-chip genre-tag">@game.Genre</MudChip>
                        </div>
                    </div>

                    <!-- Add actions -->
                    <div class="discover-actions">
                        <button class="add-btn add-btn-library" @onclick="() => Add(game, \"Library\")">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M4 11h5V5H4v6zm0 7h5v-6H4v6zm6 0h5v-6h-5v6zm6 0h5v-6h-5v6zm-6-7h5V5h-5v6zm6-6v6h5V5h-5z"/></svg>
                            Library
                        </button>
                        <button class="add-btn add-btn-playing" @onclick="() => Add(game, \"Playing\")">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                            Playing
                        </button>
                        <button class="add-btn add-btn-review" @onclick="() => Add(game, \"Review\")">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                            Review
                        </button>
                    </div>
                </div>
            </MudItem>
        }
    </MudGrid>

    @if (!Filtered.Any())
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 4rem; opacity: 0.3;" />
            <MudText Typo="Typo.h6" Class="mt-3">No games found</MudText>
            <MudText Typo="Typo.body2">Try a different search term</MudText>
        </div>
    }

</MudContainer>

