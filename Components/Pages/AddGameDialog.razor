<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add Game</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_game.Name" Label="Game Name" Required="true"
                      Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
        <MudSelect @bind-Value="_game.Genre" Label="Genre" Variant="Variant.Outlined" Class="mb-4" FullWidth="true">
            @foreach (var g in Genres)
            {
                <MudSelectItem Value="@g">@g</MudSelectItem>
            }
        </MudSelect>
        <MudSelect @bind-Value="_game.System" Label="Platform" Variant="Variant.Outlined" Class="mb-4" FullWidth="true">
            @foreach (var s in Systems)
            {
                <MudSelectItem Value="@s">@s</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_game.Developer" Label="Developer"
                      Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
        <MudGrid Spacing="2">
            <MudItem xs="6">
                <MudNumericField @bind-Value="_game.HoursPlayed" Label="Hours Played"
                                 Variant="Variant.Outlined" Min="0.0" FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_game.Review" Label="Score (0–10)"
                                 Variant="Variant.Outlined" Min="0.0" Max="10.0" Step="0.5" FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_game.HowLongToBeat" Label="HLTB (hrs)"
                                 Variant="Variant.Outlined" Min="0.0" FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_game.Year" Label="Year"
                                 Variant="Variant.Outlined" Min="2000" Max="2100" FullWidth="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(_game.Name)">
            Add Game
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private Games _game = new() { Year = DateTime.Now.Year, Review = 7.0 };

    private static readonly string[] Genres =
    {
        "Action", "Action RPG", "Action-Adventure", "JRPG", "Metroidvania",
        "MMORPG", "Platformer", "Racing", "Roguelike", "RPG", "Simulation",
        "Sports", "Strategy", "Other"
    };

    private static readonly string[] Systems =
    {
        "PC", "PlayStation 5", "PlayStation 4", "Xbox Series X", "Xbox One",
        "Nintendo Switch", "Mobile", "Other"
    };

    void Cancel() => MudDialog.Cancel();
    void Submit() => MudDialog.Close(DialogResult.Ok(_game));
}
